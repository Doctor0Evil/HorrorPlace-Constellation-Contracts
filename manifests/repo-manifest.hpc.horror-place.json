{
  "$id": "https://horror.place/manifests/repo-manifest.hpc.horror-place.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "kind": "repoManifest",
  "repoId": "hpc.horror-place",
  "displayName": "Horror.Place Constellation Contracts",
  "description": "Primary constellation contracts repository for regions, moods, events, personas, and policies.",
  "tiers": [
    "standard",
    "mature",
    "vault"
  ],
  "defaultTier": "standard",
  "registryRoots": {
    "regions": "registry/regions.ndjson",
    "moods": "registry/moods.ndjson",
    "events": "registry/events.ndjson",
    "seeds": "registry/seeds.ndjson",
    "personas": "registry/personas.ndjson",
    "policies": "registry/policies.ndjson"
  },
  "aiAuthoring": {
    "requestsDir": ".ai/requests",
    "responsesDir": ".ai/responses",
    "allowedObjectKinds": [
      "regionContractCard",
      "moodContract",
      "eventContractCard",
      "personaContractCard",
      "policyContractCard",
      "seedContractCard"
    ]
  },
  "spine": {
    "schemaIndexPath": "schemas/core/schema-spine-index-v1.json",
    "invariantsSpinePath": "schemas/core/invariants-spine.v1.json",
    "metricsSpinePath": "schemas/core/entertainment-metrics-spine.v1.json"
  }
}
