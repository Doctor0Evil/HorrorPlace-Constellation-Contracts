{
  "$id": "https://horror.place/manifests/repo-manifest.hpc.spectral-foundry.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "kind": "repoManifest",
  "repoId": "hpc.spectral-foundry",
  "displayName": "Horror.Place Spectral Foundry",
  "description": "Spectral and anomaly-focused repository for entities derived from high CIC/MDI/AOS history layers.",
  "tiers": [
    "standard",
    "mature",
    "vault"
  ],
  "defaultTier": "standard",
  "registryRoots": {
    "spectralEntities": "registry/spectral-entities.ndjson",
    "events": "registry/spectral-events.ndjson",
    "regions": "registry/spectral-regions.ndjson"
  },
  "aiAuthoring": {
    "requestsDir": ".ai/requests",
    "responsesDir": ".ai/responses",
    "allowedObjectKinds": [
      "spectralEntityContractCard",
      "eventContractCard",
      "regionContractCard"
    ]
  },
  "spine": {
    "schemaIndexPath": "schemas/core/schema-spine-index-v1.json",
    "invariantsSpinePath": "schemas/core/invariants-spine.v1.json",
    "metricsSpinePath": "schemas/core/entertainment-metrics-spine.v1.json"
  }
}
