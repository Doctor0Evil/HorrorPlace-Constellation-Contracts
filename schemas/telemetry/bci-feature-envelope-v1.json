{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema:HorrorPlace-Constellation-Contracts:bci-feature-envelope-v1.json",
  "title": "BCI Feature Envelope v1",
  "description": "Minimally processed, NDJSON-safe BCI feature container for HorrorPlace VM-Constellation. No EMA, no derived metrics, no PII, no raw EEG.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "windowId",
    "sessionId",
    "timestamp",
    "samplingRateHz",
    "windowDurationSec",
    "channelLayout",
    "features"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0",
      "description": "Semantic version of the BCI feature envelope schema."
    },
    "windowId": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for this analysis window within a session."
    },
    "sessionId": {
      "type": "string",
      "minLength": 1,
      "description": "Anonymized or pseudonymous session identifier; must not be a real-world subject or player identifier."
    },
    "timestamp": {
      "type": "integer",
      "minimum": 0,
      "description": "Window start time in Unix epoch milliseconds."
    },
    "samplingRateHz": {
      "type": "number",
      "minimum": 1,
      "maximum": 2000,
      "description": "Sampling rate of the original recording in Hertz."
    },
    "windowDurationSec": {
      "type": "number",
      "minimum": 0.1,
      "maximum": 10.0,
      "description": "Duration of this analysis window in seconds."
    },
    "channelLayout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "channels",
        "montage"
      ],
      "description": "Channel configuration used during acquisition.",
      "properties": {
        "channels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "List of channel labels used for this recording (e.g., Fz, Cz, Pz)."
        },
        "montage": {
          "type": "string",
          "enum": [
            "10-20",
            "10-10",
            "custom"
          ],
          "description": "EEG montage naming convention."
        },
        "layoutId": {
          "type": "string",
          "minLength": 1,
          "description": "Optional short identifier for the layout (e.g., custom-8ch, custom-16ch)."
        }
      }
    },
    "features": {
      "type": "array",
      "minItems": 1,
      "description": "Array of minimally processed feature objects for this window.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "featureId",
          "featureType",
          "channel",
          "value"
        ],
        "properties": {
          "featureId": {
            "type": "string",
            "minLength": 1,
            "description": "Stable identifier for this feature within the envelope."
          },
          "featureType": {
            "type": "string",
            "enum": [
              "bandpower_delta",
              "bandpower_theta",
              "bandpower_alpha",
              "bandpower_beta",
              "bandpower_gamma",
              "arousal_score",
              "valence_score",
              "asymmetry_index",
              "coherence_metric"
            ],
            "description": "Concrete feature type label aligned with upstream BCI extraction."
          },
          "featureClass": {
            "type": "string",
            "enum": [
              "bandpower",
              "differential_entropy",
              "arousal",
              "valence",
              "custom"
            ],
            "description": "High-level classification of the feature for offline analysis and tooling."
          },
          "channel": {
            "type": "string",
            "minLength": 1,
            "description": "Channel label or aggregate region name for this feature."
          },
          "value": {
            "type": "number",
            "minimum": -100,
            "maximum": 100,
            "description": "Primary scalar value of the feature (e.g., band power, entropy, score) in a normalized or log-scaled range."
          },
          "unit": {
            "type": "string",
            "minLength": 1,
            "description": "Unit of the value field when applicable (e.g., log_uV2)."
          },
          "bandPowers": {
            "type": "object",
            "additionalProperties": false,
            "description": "Optional per-band power breakdown normalized to [0, 1].",
            "properties": {
              "delta": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "theta": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "alpha": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "beta": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "gamma": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          },
          "arousalScore": {
            "type": "number",
            "minimum": -1.0,
            "maximum": 1.0,
            "description": "Optional continuous arousal score in [-1, 1]."
          },
          "valenceScore": {
            "type": "number",
            "minimum": -1.0,
            "maximum": 1.0,
            "description": "Optional continuous valence score in [-1, 1]."
          },
          "metadata": {
            "type": "object",
            "additionalProperties": false,
            "description": "Optional feature-level metadata.",
            "properties": {
              "algorithm": {
                "type": "string",
                "description": "Name or identifier of the algorithm used to compute this feature."
              },
              "version": {
                "type": "string",
                "description": "Version string for the feature extraction algorithm."
              },
              "source": {
                "type": "string",
                "description": "Optional upstream system or pipeline identifier."
              }
            }
          }
        }
      }
    }
  },
  "forbiddenFields": [
    "subjectId",
    "playerId",
    "rawWaveform",
    "sampleArray",
    "demographics",
    "medicalHistory",
    "consentStatus"
  ]
}
