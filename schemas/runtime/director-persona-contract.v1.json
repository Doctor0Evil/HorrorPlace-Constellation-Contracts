{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://horror.place/schemas/runtime/director-persona-contract.v1.json",
  "title": "Director Persona Contract v1",
  "description": "Tier-aware director persona contract defining invariant bands, entertainment metric targets, comfort policy, and runtime wiring hints for AI-directed horror sessions.",
  "type": "object",
  "additionalProperties": false,

  "required": [
    "id",
    "schemaRef",
    "objectKind",
    "tier",
    "descriptorId",
    "directorKind",
    "toneLabel",
    "allowedTier",
    "invariantBands",
    "metricTargets",
    "comfortPolicyRef",
    "prismMeta"
  ],

  "properties": {
    "id": {
      "type": "string",
      "description": "Stable director persona identifier, registry-backed.",
      "pattern": "^dir-[a-z0-9\\-]{3,64}$"
    },

    "schemaRef": {
      "type": "string",
      "description": "Schema version identifier for validator binding.",
      "const": "director-persona-contract.v1"
    },

    "objectKind": {
      "type": "string",
      "description": "Object kind for CHATDIRECTOR routing and manifest validation.",
      "const": "directorPersonaContract"
    },

    "descriptorId": {
      "type": "string",
      "description": "Authoring descriptor ID for this director persona (used by CHATDIRECTOR authoring tools).",
      "pattern": "^desc-[a-z0-9\\-]{3,32}$"
    },

    "tier": {
      "type": "string",
      "description": "Contract tier in the VM-Constellation.",
      "enum": ["standard", "mature", "research"]
    },

    "directorKind": {
      "type": "string",
      "description": "Logical director persona kind exposed to AI-Chat and routing.",
      "enum": [
        "coldOverseer",
        "ritualStatistician",
        "silentArchivistDirector",
        "custom"
      ]
    },

    "toneLabel": {
      "type": "string",
      "description": "Short label for AI-Chat style selection; human-facing but stable.",
      "minLength": 1,
      "maxLength": 64
    },

    "toneStyle": {
      "type": "string",
      "description": "Optional tone enum for localization and template routing.",
      "enum": [
        "clinical",
        "ritual",
        "archivist",
        "whisper",
        "neutral"
      ]
    },

    "allowedTier": {
      "type": "string",
      "description": "Maximum content tier this persona is permitted to operate in.",
      "enum": ["standard", "mature", "research"]
    },

    "tags": {
      "type": "array",
      "description": "Optional free-form tags for authoring and routing hints.",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      }
    },

    "invariantBands": {
      "type": "object",
      "description": "Invariant min/max bands this persona is allowed to operate within at this contract tier.",
      "additionalProperties": false,
      "required": ["CIC", "AOS", "DET", "SHCI"],
      "properties": {
        "CIC": {
          "$ref": "#/$defs/range01",
          "description": "Catastrophic Imprint Coefficient band."
        },
        "AOS": {
          "$ref": "#/$defs/range01",
          "description": "Ambient Oscillation Score band."
        },
        "MDI": {
          "$ref": "#/$defs/range01",
          "description": "Mythic Density Index band."
        },
        "RRM": {
          "$ref": "#/$defs/range01",
          "description": "Ritual Residue Map band."
        },
        "LSG": {
          "$ref": "#/$defs/range01",
          "description": "Liminal Stress Gradient band."
        },
        "SHCI": {
          "$ref": "#/$defs/range01",
          "description": "Spectral-History Coupling Index band."
        },
        "DET": {
          "$ref": "#/$defs/range0to10",
          "description": "Dread Exposure Threshold per-event band for this persona."
        }
      }
    },

    "metricTargets": {
      "type": "object",
      "description": "Target entertainment metric bands that define the director's feel at this contract tier.",
      "additionalProperties": false,
      "required": ["UEC", "EMD", "STCI", "CDL", "ARR"],
      "properties": {
        "UEC": {
          "$ref": "#/$defs/range01",
          "description": "Uncertainty Engagement Coefficient band."
        },
        "EMD": {
          "$ref": "#/$defs/range01",
          "description": "Evidential Mystery Density band."
        },
        "STCI": {
          "$ref": "#/$defs/range01",
          "description": "Safe-Threat Contrast Index band."
        },
        "CDL": {
          "$ref": "#/$defs/range01",
          "description": "Cognitive Dissonance Load band."
        },
        "ARR": {
          "$ref": "#/$defs/range01",
          "description": "Ambiguous Resolution Ratio band."
        }
      }
    },

    "comfortPolicyRef": {
      "type": "string",
      "description": "Reference to a director comfort policy defining max DET per session, cooldown ratios, and CDL span.",
      "pattern": "^dcp-[a-z0-9\\-]{3,64}$"
    },

    "styleHintPolicyRef": {
      "type": "string",
      "description": "Optional reference to a director-style-hint policy constraining styleHint codes returned by H.Director.applySafetyDecision."
    },

    "deadLedgerRef": {
      "type": "string",
      "description": "Optional Dead-Ledger attestation reference for this director persona.",
      "pattern": "^DLN\\.[a-zA-Z0-9_.-]+$"
    },

    "notes": {
      "type": "string",
      "description": "Optional human-readable notes for designers and auditors.",
      "maxLength": 2048
    },

    "prismMeta": {
      "type": "object",
      "description": "Standard prismMeta metadata block for provenance and promotion wiring.",
      "additionalProperties": true
    }
  },

  "allOf": [
    {
      "description": "Tier-aware narrowing for DET and CDL in standard tier",
      "if": {
        "properties": {
          "tier": { "const": "standard" }
        }
      },
      "then": {
        "properties": {
          "invariantBands": {
            "properties": {
              "DET": {
                "properties": {
                  "min": { "maximum": 6.0 },
                  "max": { "maximum": 6.0 }
                }
              }
            }
          },
          "metricTargets": {
            "properties": {
              "CDL": {
                "properties": {
                  "min": { "minimum": 0.0 },
                  "max": { "maximum": 0.7 }
                }
              }
            }
          }
        }
      }
    },
    {
      "description": "Tier-aware narrowing for DET and CDL in mature tier",
      "if": {
        "properties": {
          "tier": { "const": "mature" }
        }
      },
      "then": {
        "properties": {
          "invariantBands": {
            "properties": {
              "DET": {
                "properties": {
                  "min": { "maximum": 8.0 },
                  "max": { "maximum": 8.0 }
                }
              }
            }
          },
          "metricTargets": {
            "properties": {
              "CDL": {
                "properties": {
                  "min": { "minimum": 0.0 },
                  "max": { "maximum": 0.85 }
                }
              }
            }
          }
        }
      }
    },
    {
      "description": "Research tier allows full DET range but still requires explicit bounds.",
      "if": {
        "properties": {
          "tier": { "const": "research" }
        }
      },
      "then": {
        "properties": {
          "invariantBands": {
            "properties": {
              "DET": {
                "properties": {
                  "min": { "maximum": 10.0 },
                  "max": { "maximum": 10.0 }
                }
              }
            }
          },
          "metricTargets": {
            "properties": {
              "CDL": {
                "properties": {
                  "min": { "minimum": 0.0 },
                  "max": { "maximum": 1.0 }
                }
              }
            }
          }
        }
      }
    }
  ],

  "$defs": {
    "range01": {
      "type": "object",
      "description": "Generic 0–1 band with explicit min and max.",
      "required": ["min", "max"],
      "additionalProperties": false,
      "properties": {
        "min": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "max": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },
    "range0to10": {
      "type": "object",
      "description": "Generic 0–10 band for DET-like scales.",
      "required": ["min", "max"],
      "additionalProperties": false,
      "properties": {
        "min": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 10.0
        },
        "max": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 10.0
        }
      }
    }
  }
}
