{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://horror.place/schemas/runtime/run-contract.v1.json",
  "title": "RunContract v1",
  "description": "Runtime contract describing a single horror run, binding region/seed, persona, style envelopes, budget, safety, selector policy, metrics, and difficulty profiles.",
  "type": "object",
  "additionalProperties": false,

  "required": [
    "id",
    "schemaRef",
    "objectKind",
    "tier",
    "phase",
    "regionRef",
    "seedRef",
    "personaContractRef",
    "styleEnvelope",
    "budgetEnvelope",
    "safetyEnvelope",
    "historySelectorEnvelope",
    "metricsEnvelope",
    "difficultyProfile",
    "prismMeta"
  ],

  "properties": {
    "id": {
      "type": "string",
      "description": "Stable identifier for this runContract instance, registry-backed."
    },

    "schemaRef": {
      "type": "string",
      "const": "run-contract.v1",
      "description": "Schema version identifier for validator binding."
    },

    "objectKind": {
      "type": "string",
      "const": "runContract",
      "description": "Object kind for CHATDIRECTOR routing and manifest validation."
    },

    "tier": {
      "type": "string",
      "enum": [
        "standard",
        "mature",
        "research"
      ],
      "description": "Effective entitlement tier for this run, aligned with consent and routing tiers."
    },

    "phase": {
      "type": "integer",
      "enum": [2],
      "description": "Lifecycle phase; runContract is a Phase 2 Bundles artifact."
    },

    "regionRef": {
      "type": "string",
      "description": "ID or registry ref of the primary regionContractCard for this run."
    },

    "seedRef": {
      "type": "string",
      "description": "ID or registry ref of the primary seedContractCard for this run."
    },

    "eventBundleRefs": {
      "type": "array",
      "description": "Optional list of eventContract IDs associated with this run (chapters, key beats).",
      "items": {
        "type": "string"
      }
    },

    "personaContractRef": {
      "type": "string",
      "description": "ID or registry ref of the personaContract (or directorPersonaContract) that governs AI voice and behavior."
    },

    "personaRole": {
      "type": "string",
      "description": "Optional role hint for the persona (archivist, custodian, specter, etc.)."
    },

    "styleEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "styleId",
        "metricBands",
        "safetyIntent"
      ],
      "properties": {
        "styleId": {
          "type": "string",
          "description": "Primary style contract or mood style identifier for this run."
        },

        "metricBands": {
          "type": "object",
          "description": "Target bands for UEC, EMD, STCI, CDL, ARR for this run.",
          "additionalProperties": false,
          "properties": {
            "UEC": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 2,
              "maxItems": 2,
              "description": "Uncertainty Engagement Coefficient band [min, max]."
            },
            "EMD": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 2,
              "maxItems": 2,
              "description": "Evidential Mystery Density band [min, max]."
            },
            "STCI": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 2,
              "maxItems": 2,
              "description": "Safe-Threat Contrast Index band [min, max]."
            },
            "CDL": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 2,
              "maxItems": 2,
              "description": "Cognitive Dissonance Load band [min, max]."
            },
            "ARR": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 2,
              "maxItems": 2,
              "description": "Ambiguous Resolution Ratio band [min, max]."
            }
          }
        },

        "safetyIntent": {
          "type": "object",
          "additionalProperties": false,
          "description": "Mini safety vector for this run that must agree with consent, content boundary, and horror-intensity-budget policy.",
          "properties": {
            "maxCIC": {
              "type": "number",
              "description": "Maximum Catastrophic Imprint Coefficient targeted for this run."
            },
            "maxDET": {
              "type": "number",
              "description": "Maximum Dread Exposure Threshold targeted per-event within this run."
            },
            "maxGXI": {
              "type": "number",
              "description": "Maximum graphical explicitness index (GXI) allowed under consent and budget."
            },
            "allowImpliedBodyHarm": {
              "type": "boolean",
              "description": "Whether implied body harm is permitted within tier and consent caps."
            },
            "allowExplicitGore": {
              "type": "boolean",
              "description": "Whether explicit gore is permitted; typically false outside highest tiers."
            },
            "notes": {
              "type": "string",
              "maxLength": 2048,
              "description": "Optional human-readable notes for safety and governance review."
            }
          }
        }
      }
    },

    "budgetEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policyRef",
        "initialBudget",
        "perModality"
      ],
      "properties": {
        "policyRef": {
          "type": "string",
          "description": "Reference to horror-intensity-budget-policy contract controlling modality ceilings."
        },

        "initialBudget": {
          "type": "number",
          "description": "Scalar budget weight for this session derived from consent, history, and profile."
        },

        "perModality": {
          "type": "object",
          "additionalProperties": false,
          "description": "Per-modality budgets e.g., violence, gore, sexual, psychological.",
          "properties": {
            "violence": {
              "type": "object",
              "required": ["max"],
              "additionalProperties": false,
              "properties": {
                "max": { "type": "number" },
                "softCap": { "type": "number" },
                "hardCap": { "type": "number" }
              }
            },
            "gore": {
              "type": "object",
              "required": ["max"],
              "additionalProperties": false,
              "properties": {
                "max": { "type": "number" },
                "softCap": { "type": "number" },
                "hardCap": { "type": "number" }
              }
            },
            "sexual": {
              "type": "object",
              "required": ["max"],
              "additionalProperties": false,
              "properties": {
                "max": { "type": "number" },
                "softCap": { "type": "number" },
                "hardCap": { "type": "number" }
              }
            },
            "psychological": {
              "type": "object",
              "required": ["max"],
              "additionalProperties": false,
              "properties": {
                "max": { "type": "number" },
                "softCap": { "type": "number" },
                "hardCap": { "type": "number" }
              }
            }
          }
        }
      }
    },

    "safetyEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chatSafetyRulesetId",
        "banterPolicyRef",
        "consentStateRef"
      ],
      "properties": {
        "chatSafetyRulesetId": {
          "type": "string",
          "description": "ID of the chat-safety-invariants / content-boundary ruleset to apply."
        },
        "banterPolicyRef": {
          "type": "string",
          "description": "Reference to input-banter-policy for classification and routing."
        },
        "consentStateRef": {
          "type": "string",
          "description": "Reference to consent-state-machine / consent profile snapshot governing this run."
        }
      }
    },

    "historySelectorEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selectorPolicyRef",
        "patternGovernanceRef"
      ],
      "properties": {
        "selectorPolicyRef": {
          "type": "string",
          "description": "Reference to history-selector-rule / selector policy contract."
        },
        "patternGovernanceRef": {
          "type": "string",
          "description": "Reference to history-selector-pattern-governance policy."
        }
      }
    },

    "metricsEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "invariantTargets",
        "metricTargets"
      ],
      "properties": {
        "invariantTargets": {
          "type": "object",
          "description": "Per-run invariant targets keyed by abbreviation CIC, DET, AOS, SHCI, etc.",
          "additionalProperties": {
            "type": "number"
          }
        },
        "metricTargets": {
          "type": "object",
          "description": "Per-run entertainment metric targets keyed by abbreviation UEC, EMD, STCI, CDL, ARR.",
          "additionalProperties": {
            "type": "number"
          }
        }
      }
    },

    "difficultyProfile": {
      "type": "object",
      "description": "Difficulty-specific bands for skills, world invariants, and metrics keyed by difficulty name (e.g., Novice, Standard, Expert).",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "skillBands": {
            "type": "object",
            "description": "Expected player or persona skill bands for this difficulty.",
            "additionalProperties": false,
            "properties": {
              "analysisSkill": { "$ref": "#/$defs/range01" },
              "intuitionSkill": { "$ref": "#/$defs/range01" },
              "riskTolerance": { "$ref": "#/$defs/range01" }
            }
          },
          "worldInvariants": {
            "type": "object",
            "description": "Run-level invariant bands for this difficulty.",
            "additionalProperties": false,
            "properties": {
              "CIC": { "$ref": "#/$defs/range01" },
              "AOS": { "$ref": "#/$defs/range01" },
              "DET": { "$ref": "#/$defs/range10" },
              "SHCI": { "$ref": "#/$defs/range01" }
            }
          },
          "metricTargets": {
            "type": "object",
            "description": "Target UEC, EMD, STCI, CDL, ARR bands for this difficulty.",
            "additionalProperties": false,
            "properties": {
              "UEC": { "$ref": "#/$defs/range01" },
              "EMD": { "$ref": "#/$defs/range01" },
              "STCI": { "$ref": "#/$defs/range01" },
              "CDL": { "$ref": "#/$defs/range01" },
              "ARR": { "$ref": "#/$defs/range01" }
            }
          }
        },
        "required": [
          "skillBands",
          "worldInvariants",
          "metricTargets"
        ]
      }
    },

    "imageHelper": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional configuration for image-helper behavior and constraints.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether image-helper is allowed for this run."
        },
        "stylePacks": {
          "type": "array",
          "description": "List of style-pack identifiers that image-helper may use.",
          "items": { "type": "string" }
        },
        "maxImagesPerRun": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum number of images that may be requested or displayed during the run."
        },
        "safetyProfileRef": {
          "type": "string",
          "description": "Reference to an image-safety policy contract."
        }
      }
    },

    "prismMeta": {
      "type": "object",
      "description": "Standard prismMeta metadata block; shape defined in prismMeta.v1.json.",
      "additionalProperties": true
    },

    "deadLedgerRef": {
      "type": "string",
      "description": "Optional Dead-Ledger attestation reference for this runContract."
    }
  },

  "$defs": {
    "range01": {
      "type": "object",
      "description": "Inclusive [min, max] range within [0.0, 1.0].",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "max": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },
    "range10": {
      "type": "object",
      "description": "Inclusive [min, max] range within [0.0, 10.0], suitable for DET bands.",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 10.0
        },
        "max": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 10.0
        }
      }
    }
  }
}
