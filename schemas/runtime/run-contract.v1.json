{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://horror.place/schemas/runtime/run-contract.v1.json",
  "title": "RunContract",
  "description": "Runtime contract describing a single horror run binding region/seed, persona, style envelopes, budget, and safety surfaces.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schemaRef",
    "objectKind",
    "tier",
    "phase",
    "regionRef",
    "seedRef",
    "personaContractRef",
    "styleEnvelope",
    "budgetEnvelope",
    "safetyEnvelope",
    "historySelectorEnvelope",
    "metricsEnvelope",
    "prismMeta"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable identifier for this runContract instance."
    },
    "schemaRef": {
      "type": "string",
      "const": "runContract.v1",
      "description": "Schema version identifier."
    },
    "objectKind": {
      "type": "string",
      "const": "runContract",
      "description": "Object kind for CHATDIRECTOR routing."
    },
    "tier": {
      "type": "string",
      "enum": [
        "Tier1Public",
        "Tier2Internal",
        "Tier3Vault",
        "Tier4Underground"
      ],
      "description": "Effective entitlement tier for this run."
    },
    "phase": {
      "type": "integer",
      "enum": [2],
      "description": "CHATDIRECTOR lifecycle phase; runContract is a Phase 2 Bundles artifact."
    },

    "regionRef": {
      "type": "string",
      "description": "ID or registry ref of the primary regionContractCard for this run."
    },
    "seedRef": {
      "type": "string",
      "description": "ID or registry ref of the primary seedContractCard for this run."
    },
    "eventBundleRefs": {
      "type": "array",
      "description": "Optional list of eventContract IDs associated with this run.",
      "items": {
        "type": "string"
      }
    },

    "personaContractRef": {
      "type": "string",
      "description": "ID or registry ref of the personaContract that governs AI voice and behavior."
    },
    "personaRole": {
      "type": "string",
      "description": "Optional role hint for the persona (archivist, custodian, specter, etc.)."
    },

    "styleEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "styleId",
        "metricBands",
        "safetyIntent"
      ],
      "properties": {
        "styleId": {
          "type": "string",
          "description": "Primary style contract or mood style identifier."
        },
        "metricBands": {
          "type": "object",
          "description": "Target bands for UEC, EMD, STCI, CDL, ARR for this run.",
          "additionalProperties": false,
          "properties": {
            "UEC": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
            "EMD": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
            "STCI": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
            "CDL": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
            "ARR": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 }
          }
        },
        "safetyIntent": {
          "type": "object",
          "additionalProperties": false,
          "description": "Mini safety vector for this run that must agree with content boundary rules.",
          "properties": {
            "maxCIC": { "type": "number" },
            "maxDET": { "type": "number" },
            "maxGXI": { "type": "number" },
            "allowImpliedBodyHarm": { "type": "boolean" },
            "allowExplicitGore": { "type": "boolean" },
            "notes": { "type": "string" }
          }
        }
      }
    },

    "budgetEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policyRef",
        "initialBudget",
        "perModality"
      ],
      "properties": {
        "policyRef": {
          "type": "string",
          "description": "Reference to horror-intensity-budget-policy contract."
        },
        "initialBudget": {
          "type": "number",
          "description": "Scalar budget weight for this session derived from consent + history."
        },
        "perModality": {
          "type": "object",
          "additionalProperties": false,
          "description": "Per-modality budgets violence, gore, sexual, psychological.",
          "properties": {
            "violence": {
              "type": "object",
              "required": ["max"],
              "additionalProperties": false,
              "properties": {
                "max": { "type": "number" },
                "softCap": { "type": "number" },
                "hardCap": { "type": "number" }
              }
            },
            "gore": {
              "type": "object",
              "required": ["max"],
              "additionalProperties": false,
              "properties": {
                "max": { "type": "number" },
                "softCap": { "type": "number" },
                "hardCap": { "type": "number" }
              }
            },
            "sexual": {
              "type": "object",
              "required": ["max"],
              "additionalProperties": false,
              "properties": {
                "max": { "type": "number" },
                "softCap": { "type": "number" },
                "hardCap": { "type": "number" }
              }
            },
            "psychological": {
              "type": "object",
              "required": ["max"],
              "additionalProperties": false,
              "properties": {
                "max": { "type": "number" },
                "softCap": { "type": "number" },
                "hardCap": { "type": "number" }
              }
            }
          }
        }
      }
    },

    "safetyEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chatSafetyRulesetId",
        "banterPolicyRef",
        "consentStateRef"
      ],
      "properties": {
        "chatSafetyRulesetId": {
          "type": "string",
          "description": "ID of the content-boundary ruleset to apply."
        },
        "banterPolicyRef": {
          "type": "string",
          "description": "Reference to input-banter-policy for this run."
        },
        "consentStateRef": {
          "type": "string",
          "description": "Reference to consent-state-machine / consent profile snapshot."
        }
      }
    },

    "historySelectorEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selectorPolicyRef",
        "patternGovernanceRef"
      ],
      "properties": {
        "selectorPolicyRef": {
          "type": "string",
          "description": "Reference to history-selector policy contract."
        },
        "patternGovernanceRef": {
          "type": "string",
          "description": "Reference to history-selector-pattern-governance."
        }
      }
    },

    "metricsEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "invariantTargets",
        "metricTargets"
      ],
      "properties": {
        "invariantTargets": {
          "type": "object",
          "description": "Per-run invariant targets keyed by abbreviation CIC, DET, etc.",
          "additionalProperties": {
            "type": "number"
          }
        },
        "metricTargets": {
          "type": "object",
          "description": "Per-run entertainment metric targets keyed by abbreviation UEC, ARR, etc.",
          "additionalProperties": {
            "type": "number"
          }
        }
      }
    },

    "imageHelper": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional configuration for image helper behavior and constraints.",
      "properties": {
        "enabled": { "type": "boolean" },
        "stylePacks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "maxImagesPerRun": { "type": "integer", "minimum": 0 },
        "safetyProfileRef": {
          "type": "string",
          "description": "Reference to an image-safety policy contract."
        }
      }
    },

    "prismMeta": {
      "type": "object",
      "description": "Standard prismMeta metadata block; shape defined in prismMeta.v1.json.",
      "additionalProperties": true
    },

    "deadLedgerRef": {
      "type": "string",
      "description": "Optional Dead-Ledger attestation reference for this runContract."
    }
  }
}
