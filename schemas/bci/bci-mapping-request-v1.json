{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "bci-mapping-request-v1",
  "description": "Unified mapping request aggregating BCI state, invariants, metrics, and context for kernel processing.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaId": {
      "type": "string",
      "const": "bci-mapping-request-v1"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "sessionId": {
      "type": "string"
    },
    "playerId": {
      "type": "string",
      "description": "Anonymized player identifier."
    },
    "tickIndex": {
      "type": "integer",
      "minimum": 0
    },
    "regionId": {
      "type": "string",
      "description": "Current region/tile identifier."
    },
    "tileId": {
      "type": "string",
      "description": "Current tile identifier within region."
    },
    "invariants": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cic": { "type": "number", "minimum": 0, "maximum": 1 },
        "mdi": { "type": "number", "minimum": 0, "maximum": 1 },
        "aos": { "type": "number", "minimum": 0, "maximum": 1 },
        "lsg": { "type": "number", "minimum": 0, "maximum": 1 },
        "spr": { "type": "number", "minimum": 0, "maximum": 1 },
        "rrm": { "type": "number", "minimum": 0, "maximum": 1 },
        "fcf": { "type": "number", "minimum": 0, "maximum": 1 },
        "rwf": { "type": "number", "minimum": 0, "maximum": 1 },
        "hvf": { "type": "number", "minimum": 0, "maximum": 1 },
        "shci": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "required": ["cic", "mdi", "aos", "lsg", "spr", "rrm", "fcf", "rwf", "hvf", "shci"]
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "uec": { "type": "number", "minimum": 0, "maximum": 1 },
        "emd": { "type": "number", "minimum": 0, "maximum": 1 },
        "stci": { "type": "number", "minimum": 0, "maximum": 1 },
        "cdl": { "type": "number", "minimum": 0, "maximum": 1 },
        "arr": { "type": "number", "minimum": 0, "maximum": 1 },
        "det": { "type": "number", "minimum": 0, "maximum": 10 }
      },
      "required": ["uec", "emd", "stci", "cdl", "arr", "det"]
    },
    "bciSummary": {
      "type": "object",
      "$ref": "#/definitions/bciSummaryRef"
    },
    "csi": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "contractContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "presetId": { "type": "string" },
        "tier": { "type": "string", "enum": ["standard", "mature", "research"] },
        "safetyProfileId": { "type": "string" }
      },
      "required": ["presetId", "tier", "safetyProfileId"]
    }
  },
  "definitions": {
    "bciSummaryRef": {
      "type": "object",
      "properties": {
        "stressScore": { "type": "number", "minimum": 0, "maximum": 1 },
        "stressBand": { "type": "string", "enum": ["UNDERSTIMULATED", "OPTIMALSTRESS", "OVERWHELMED"] },
        "attentionBand": { "type": "string", "enum": ["Distracted", "Neutral", "Focused", "HyperFocused"] },
        "visualOverloadIndex": { "type": "number", "minimum": 0, "maximum": 1 },
        "startleSpike": { "type": "integer", "enum": [0, 1] },
        "signalQuality": { "type": "string", "enum": ["Good", "Degraded", "Unavailable"] },
        "modeTransitionCooldown": { "type": "number", "minimum": 0 }
      }
    }
  },
  "required": [
    "schemaId",
    "schemaVersion",
    "sessionId",
    "playerId",
    "tickIndex",
    "regionId",
    "tileId",
    "invariants",
    "metrics",
    "bciSummary",
    "csi",
    "contractContext"
  ]
}
