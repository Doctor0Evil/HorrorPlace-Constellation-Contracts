{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema:HorrorPlace-Constellation-Contracts:bci-geometry-binding-v1.json",
  "title": "BCI Geometry Binding v1",
  "description": "Defines how BciSummary fields, invariants, entertainment metrics, and CSI select curve families and safety profiles to drive visual, audio, and haptic parameters. Bindings are configuration objects, not runtime envelopes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "bindingId",
    "regionClass",
    "tier",
    "invariantFilter",
    "bciFilter",
    "metricsFilter",
    "safetyProfile",
    "targets",
    "curves"
  ],
  "properties": {
    "schemaId": {
      "type": "string",
      "const": "hpnrl-bci-geometry-binding-v1",
      "description": "Stable identifier for this binding schema."
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semantic version of this binding schema (MAJOR.MINOR.PATCH), e.g. 1.0.0."
    },
    "bindingId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Stable, human-readable identifier for this binding, e.g. 'corridor-highCIC-medStress-sigmoidTunnel'."
    },
    "regionClass": {
      "type": "string",
      "enum": [
        "corridor",
        "chamber",
        "threshold",
        "open",
        "liminal",
        "sanctuary"
      ],
      "description": "Coarse environmental classification. Specific invariant ranges are declared in invariantFilter."
    },
    "tier": {
      "type": "string",
      "enum": [
        "lab",
        "standard",
        "mature",
        "research"
      ],
      "description": "Promotion tier for this binding. Runtime should only allow 'standard' or 'mature' in production sessions."
    },
    "priority": {
      "type": "number",
      "minimum": 0,
      "maximum": 10,
      "default": 5,
      "description": "Optional explicit priority for resolver tie-breaking. Higher values are preferred when multiple bindings match."
    },
    "invariantFilter": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional min/max ranges for invariants; unspecified fields are unconstrained.",
      "properties": {
        "cic": {
          "$ref": "#/$defs/range01"
        },
        "mdi": {
          "$ref": "#/$defs/range01"
        },
        "aos": {
          "$ref": "#/$defs/range01"
        },
        "det": {
          "$ref": "#/$defs/range010"
        },
        "hvf": {
          "$ref": "#/$defs/range01"
        },
        "lsg": {
          "$ref": "#/$defs/range01"
        },
        "spr": {
          "$ref": "#/$defs/range01"
        },
        "shci": {
          "$ref": "#/$defs/range01"
        }
      }
    },
    "bciFilter": {
      "type": "object",
      "additionalProperties": false,
      "description": "Filters expressed only in terms of BciSummary fields. All fields are optional; unspecified fields are unconstrained.",
      "properties": {
        "stressScoreMin": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "stressScoreMax": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "stressBand": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Low",
              "Medium",
              "High",
              "Extreme"
            ]
          },
          "uniqueItems": true
        },
        "attentionBand": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Distracted",
              "Neutral",
              "Focused",
              "HyperFocused"
            ]
          },
          "uniqueItems": true
        },
        "visualOverloadMin": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "visualOverloadMax": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "allowStartleSpike": {
          "type": "boolean",
          "description": "If false, this binding must not activate when BciSummary.startleSpike is true."
        },
        "signalQuality": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Good",
              "Degraded",
              "Unavailable"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "metricsFilter": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional gating on entertainment metrics; metrics are an extra observation channel, not a new metric system.",
      "properties": {
        "uecBand": {
          "$ref": "#/$defs/range01"
        },
        "emdBand": {
          "$ref": "#/$defs/range01"
        },
        "stciBand": {
          "$ref": "#/$defs/range01"
        },
        "cdlBand": {
          "$ref": "#/$defs/range01"
        },
        "arrBand": {
          "$ref": "#/$defs/range01"
        }
      }
    },
    "inputWeights": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional scalar weights for resolver scoring; sum is not enforced but recommended to be near 1.0.",
      "properties": {
        "stressScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.4
        },
        "visualOverloadIndex": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.2
        },
        "attentionBand": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.1
        },
        "uec": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.1
        },
        "arr": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.1
        },
        "cic": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.05
        },
        "lsg": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.05
        }
      }
    },
    "targets": {
      "type": "object",
      "additionalProperties": false,
      "description": "Declares which output channels this binding intends to drive.",
      "properties": {
        "visual": {
          "type": "boolean",
          "default": true
        },
        "audio": {
          "type": "boolean",
          "default": true
        },
        "haptics": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "curves": {
      "type": "object",
      "additionalProperties": false,
      "description": "Curve family assignments per output channel.",
      "required": [
        "visual",
        "audio",
        "haptics"
      ],
      "properties": {
        "visual": {
          "$ref": "#/$defs/curveAssignment"
        },
        "audio": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "pressureLf": {
              "$ref": "#/$defs/curveAssignment"
            },
            "whisperSend": {
              "$ref": "#/$defs/curveAssignment"
            },
            "stereoWidth": {
              "$ref": "#/$defs/curveAssignment"
            },
            "noiseGrain": {
              "$ref": "#/$defs/curveAssignment"
            }
          }
        },
        "haptics": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "intensity": {
              "$ref": "#/$defs/curveAssignment"
            },
            "pulseHz": {
              "$ref": "#/$defs/curveAssignment"
            }
          }
        }
      }
    },
    "safetyProfile": {
      "type": "string",
      "minLength": 1,
      "description": "Reference to bci-safety-profile-v1 profileId that defines CSI/DET and intensity caps for this binding."
    },
    "notes": {
      "type": "string",
      "description": "Optional human-readable description of this binding's intent and expected effect."
    }
  },
  "$defs": {
    "range01": {
      "type": "object",
      "additionalProperties": false,
      "description": "Closed interval [min,max] in the normalized 0–1 domain.",
      "properties": {
        "min": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "max": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "range010": {
      "type": "object",
      "additionalProperties": false,
      "description": "Closed interval [min,max] in the normalized 0–10 domain, used for DET-like indices.",
      "properties": {
        "min": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        },
        "max": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        }
      }
    },
    "curveAssignment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "familyCode",
        "params"
      ],
      "properties": {
        "familyCode": {
          "type": "string",
          "enum": [
            "PKLIN",
            "PKSIG",
            "PKHYS",
            "PKRHY",
            "PKAMB",
            "PKSTC"
          ],
          "description": "Curve family identifier. PKLIN=linear, PKSIG=sigmoid, PKHYS=hysteresis, PKRHY=oscillatory/rhythmic, PKAMB=ambient, PKSTC=step/stepped."
        },
        "params": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "type": "number"
          },
          "description": "Exactly four numeric parameters for the chosen curve family. Interpretation is defined by the Rust kernel."
        }
      }
    }
  }
}
