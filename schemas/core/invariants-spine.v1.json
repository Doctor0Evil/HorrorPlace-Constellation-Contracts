{
  "$id": "https://horrorplace.org/schemas/core/invariants-spine.v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HorrorPlace Invariants Spine v1",
  "description": "Canonical invariant definitions, numeric ranges, derived metric formulas, interaction rules, and safe default bands for the HorrorPlace constellation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "invariants",
    "derivedMetrics",
    "interactionRules",
    "safeDefaults"
  ],
  "properties": {
    "version": {
      "type": "string",
      "description": "Semantic version of this invariant spine document, e.g., 1.0.0.",
      "pattern": "^1\\.0\\.0(-[a-z0-9]+)?$"
    },
    "invariants": {
      "type": "array",
      "description": "Authoritative invariant rows, including historical, entertainment, derived, and reliability invariants.",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "code",
          "name",
          "description",
          "class",
          "range",
          "tierOverrides",
          "drift",
          "spineMetricBindings"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable identifier for this invariant row.",
            "pattern": "^INV-[0-9]{3}$"
          },
          "code": {
            "type": "string",
            "description": "Short invariant or metric code carried on contracts and telemetry.",
            "enum": [
              "CIC",
              "MDI",
              "AOS",
              "RRM",
              "FCF",
              "LSG",
              "HVF",
              "DET",
              "SPR",
              "SHCI",
              "RWF",
              "UEC",
              "EMD",
              "STCI",
              "CDL",
              "ARR"
            ]
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Canonical human-readable name for this code."
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "description": "High-level description of what this invariant or metric measures and how it is interpreted."
          },
          "class": {
            "type": "string",
            "description": "Classification used by CI and routing when narrowing bands.",
            "enum": [
              "HISTORICAL",
              "ENTERTAINMENT",
              "DERIVED",
              "RELIABILITY"
            ]
          },
          "range": {
            "type": "object",
            "description": "Global domain for this invariant across all tiers, before overrides.",
            "additionalProperties": false,
            "required": [
              "min",
              "max",
              "step"
            ],
            "properties": {
              "min": {
                "type": "number"
              },
              "max": {
                "type": "number"
              },
              "step": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            }
          },
          "tierOverrides": {
            "type": "array",
            "description": "Per-tier bands that must sit inside the global range. Child envelopes must choose subsets of these bands.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "tier",
                "min",
                "max"
              ],
              "properties": {
                "tier": {
                  "type": "string",
                  "enum": [
                    "TIER1_PUBLIC",
                    "TIER2_MATURE",
                    "TIER3_RESEARCH"
                  ]
                },
                "min": {
                  "type": "number"
                },
                "max": {
                  "type": "number"
                }
              }
            }
          },
          "drift": {
            "type": "object",
            "description": "Schema-level guardrails on how much this invariant band may change across releases.",
            "additionalProperties": false,
            "required": [
              "allowed",
              "maxDeltaPerRelease"
            ],
            "properties": {
              "allowed": {
                "type": "boolean"
              },
              "maxDeltaPerRelease": {
                "type": "number",
                "minimum": 0
              }
            }
          },
          "spineMetricBindings": {
            "type": "array",
            "description": "Bindings to telemetry or runtime metrics that this invariant constrains or derives from.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "metricName",
                "role"
              ],
              "properties": {
                "metricName": {
                  "type": "string",
                  "enum": [
                    "CIC",
                    "MDI",
                    "AOS",
                    "RRM",
                    "FCF",
                    "LSG",
                    "HVF",
                    "DET",
                    "SPR",
                    "SHCI",
                    "RWF",
                    "UEC",
                    "EMD",
                    "STCI",
                    "CDL",
                    "ARR"
                  ]
                },
                "role": {
                  "type": "string",
                  "enum": [
                    "PRIMARY",
                    "SECONDARY",
                    "DERIVED_INPUT"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "derivedMetrics": {
      "type": "array",
      "description": "Explicit formulas for derived metrics like SPR and SHCI. Engines and CHAT_DIRECTOR must treat these as authoritative.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "inputs",
          "formula",
          "notes"
        ],
        "properties": {
          "code": {
            "type": "string",
            "enum": [
              "SPR",
              "SHCI"
            ]
          },
          "inputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "CIC",
                "MDI",
                "AOS",
                "RRM",
                "FCF",
                "LSG",
                "HVF",
                "DET",
                "RWF",
                "UEC",
                "EMD",
                "STCI",
                "CDL",
                "ARR"
              ]
            }
          },
          "formula": {
            "type": "object",
            "description": "Formula encoded as a weighted linear combination plus optional clamps and nonlinear segments.",
            "additionalProperties": false,
            "required": [
              "type",
              "weights",
              "bias",
              "clamp"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "WEIGHTED_SUM",
                  "PIECEWISE_LINEAR"
                ]
              },
              "weights": {
                "type": "object",
                "description": "Map from input metric code to weight.",
                "additionalProperties": {
                  "type": "number"
                }
              },
              "bias": {
                "type": "number"
              },
              "clamp": {
                "type": "object",
                "required": [
                  "min",
                  "max"
                ],
                "additionalProperties": false,
                "properties": {
                  "min": {
                    "type": "number"
                  },
                  "max": {
                    "type": "number"
                  }
                }
              },
              "piecewise": {
                "type": "array",
                "description": "Optional piecewise adjustments applied after base computation.",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "predicate",
                    "delta"
                  ],
                  "properties": {
                    "predicate": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": [
                        "metric",
                        "op",
                        "value"
                      ],
                      "properties": {
                        "metric": {
                          "type": "string"
                        },
                        "op": {
                          "type": "string",
                          "enum": [
                            "<",
                            "<=",
                            ">",
                            ">=",
                            "=="
                          ]
                        },
                        "value": {
                          "type": "number"
                        }
                      }
                    },
                    "delta": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "interactionRules": {
      "type": "array",
      "description": "Cross-metric coupling rules that adjust effective bands for one metric based on another.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ruleId",
          "sourceMetric",
          "targetMetric",
          "relationship",
          "condition",
          "effect"
        ],
        "properties": {
          "ruleId": {
            "type": "string",
            "pattern": "^XMIT-[0-9]{3}$"
          },
          "sourceMetric": {
            "type": "string",
            "enum": [
              "CIC",
              "MDI",
              "AOS",
              "RRM",
              "FCF",
              "LSG",
              "HVF",
              "DET",
              "SPR",
              "SHCI",
              "RWF",
              "UEC",
              "EMD",
              "STCI",
              "CDL",
              "ARR"
            ]
          },
          "targetMetric": {
            "type": "string",
            "enum": [
              "CIC",
              "MDI",
              "AOS",
              "RRM",
              "FCF",
              "LSG",
              "HVF",
              "DET",
              "SPR",
              "SHCI",
              "RWF",
              "UEC",
              "EMD",
              "STCI",
              "CDL",
              "ARR"
            ]
          },
          "relationship": {
            "type": "string",
            "enum": [
              "SUPPRESS",
              "AMPLIFY",
              "GATE"
            ]
          },
          "condition": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "op",
              "threshold"
            ],
            "properties": {
              "op": {
                "type": "string",
                "enum": [
                  "<",
                  "<=",
                  ">",
                  ">=",
                  "=="
                ]
              },
              "threshold": {
                "type": "number"
              }
            }
          },
          "effect": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "minDelta",
              "maxDelta"
            ],
            "properties": {
              "minDelta": {
                "type": "number"
              },
              "maxDelta": {
                "type": "number"
              }
            }
          }
        }
      }
    },
    "safeDefaults": {
      "type": "array",
      "description": "Conservative invariant and metric bands per objectKind and tier that guarantee validation passage for first drafts.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "objectKind",
          "tier",
          "bands"
        ],
        "properties": {
          "objectKind": {
            "type": "string",
            "enum": [
              "regionContractCard",
              "seedContractCard",
              "moodContract",
              "eventContract"
            ]
          },
          "tier": {
            "type": "string",
            "enum": [
              "TIER1_PUBLIC",
              "TIER2_MATURE",
              "TIER3_RESEARCH"
            ]
          },
          "bands": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "CIC": {
                "type": "object",
                "required": [
                  "min",
                  "max"
                ],
                "properties": {
                  "min": {
                    "type": "number"
                  },
                  "max": {
                    "type": "number"
                  }
                }
              },
              "AOS": {
                "type": "object",
                "required": [
                  "min",
                  "max"
                ],
                "properties": {
                  "min": {
                    "type": "number"
                  },
                  "max": {
                    "type": "number"
                  }
                }
              },
              "DET": {
                "type": "object",
                "required": [
                  "min",
                  "max"
                ],
                "properties": {
                  "min": {
                    "type": "number"
                  },
                  "max": {
                    "type": "number"
                  }
                }
              },
              "UEC": {
                "type": "object",
                "required": [
                  "min",
                  "max"
                ],
                "properties": {
                  "min": {
                    "type": "number"
                  },
                  "max": {
                    "type": "number"
                  }
                }
              },
              "ARR": {
                "type": "object",
                "required": [
                  "min",
                  "max"
                ],
                "properties": {
                  "min": {
                    "type": "number"
                  },
                  "max": {
                    "type": "number"
                  }
                }
              },
              "SHCI": {
                "type": "object",
                "required": [
                  "min",
                  "max"
                ],
                "properties": {
                  "min": {
                    "type": "number"
                  },
                  "max": {
                    "type": "number"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
