{
  "$id": "https://schemas.horror.place/ai/ai-bci-geometry-request.monster-mode-v1.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AiBciGeometryRequest.MonsterMode.V1",
  "description": "Constrained .aln request envelope for AI-authored monster-mode BCI geometry bindings.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestId",
    "experienceType",
    "infectionProfile",
    "targets",
    "constraints"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "ai-bci-geometry-request-v1"
    },
    "requestId": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_.-]+$"
    },
    "experienceType": {
      "type": "string",
      "enum": [
        "monster-mode"
      ]
    },
    "infectionProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "style"
      ],
      "properties": {
        "style": {
          "type": "string",
          "enum": [
            "shambler",
            "runner",
            "seer"
          ]
        },
        "durationHintSec": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 600.0
        },
        "coopEmphasis": {
          "type": "string",
          "enum": [
            "squad-first",
            "self-first"
          ]
        }
      }
    },
    "targets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bindingProfileId",
        "targetRepo",
        "targetPath"
      ],
      "properties": {
        "bindingProfileId": {
          "type": "string",
          "pattern": "^[a-z0-9_.-]+$"
        },
        "targetRepo": {
          "type": "string",
          "enum": [
            "HorrorPlace-Neural-Resonance-Lab",
            "Death-Engine"
          ]
        },
        "targetPath": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_./-]+$"
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowedSummaryFields",
        "allowedOutputs",
        "allowedSafetyProfiles"
      ],
      "properties": {
        "allowedSummaryFields": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "stressScore",
              "stressBand",
              "attentionBand",
              "visualOverloadIndex",
              "startleSpike",
              "signalQuality"
            ]
          },
          "minItems": 1
        },
        "allowedInvariants": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "CIC",
              "AOS",
              "DET",
              "LSG"
            ]
          }
        },
        "allowedOutputs": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "visual",
            "audio",
            "haptics"
          ],
          "properties": {
            "visual": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "maskRadius",
                  "maskFeather",
                  "decayGrain",
                  "colorDesat",
                  "veinOverlay",
                  "motionSmear"
                ]
              }
            },
            "audio": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "infectedChannelGain",
                  "squadMuffle",
                  "heartbeatGain",
                  "breathGain",
                  "ringingLevel",
                  "directionBias"
                ]
              }
            },
            "haptics": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "chestPressure",
                  "spineCrawl",
                  "tremorRate"
                ]
              }
            }
          }
        },
        "allowedSafetyProfiles": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "monster-mode-standard",
              "monster-mode-safe-room"
            ]
          },
          "minItems": 1
        },
        "maxBindings": {
          "type": "integer",
          "minimum": 1,
          "maximum": 64
        }
      }
    },
    "authoringHints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "regionClasses": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "corridor-highCIC-highAOS-build",
              "threshold-highDET-apex",
              "safe-lowDET-cooldown",
              "infection-hub",
              "infection-approach",
              "infection-retreat"
            ]
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
