{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema:HorrorPlace-Constellation-Contracts:ai-bci-geometry-response-v1.json",
  "title": "AI BCI Geometry Response v1",
  "description": "Response envelope for AI-chat when returning generated bci-geometry-binding-v1 objects. All bindings must validate against bci-geometry-binding-v1.json.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "bindings"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "schema:HorrorPlace-Constellation-Contracts:bci-geometry-binding-v1.json"
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "authorAgent": { "type": "string" },
        "notes": { "type": "string" },
        "validationWarnings": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
