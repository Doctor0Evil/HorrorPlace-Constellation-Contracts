{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://horror.place/schemas/seed-ritual-contract-v1.json",
  "title": "Seed-Ritual Contract v1",
  "description": "Tier-1 Seed-Ritual contract binding Seeds into a five-stage horror arc with entertainment, audiovisual, GXI, and governance bands.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "ritualId",
    "version",
    "consentTier",
    "gxiCap",
    "explicitViolenceForbidden",
    "stageBindings",
    "stageMetricBands",
    "stageIntensityEnvelopes"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "format": "uri",
      "const": "https://horror.place/schemas/seed-ritual-contract-v1.json"
    },
    "ritualId": {
      "type": "string",
      "description": "Stable identifier for this Seed-Ritual contract.",
      "pattern": "^[a-z0-9_.-]{8,64}$"
    },
    "version": {
      "type": "string",
      "description": "Semantic version for this Seed-Ritual contract.",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[0-9A-Za-z.-]+)?$"
    },
    "consentTier": {
      "type": "string",
      "enum": [
        "Tier1Public",
        "Tier2Internal",
        "Tier3Vault"
      ]
    },
    "gxiCap": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 10.0
    },
    "explicitViolenceForbidden": {
      "type": "boolean",
      "description": "Must be true for Tier1Public and Tier2Internal rituals; enforced by CI and gxicap lints."
    },

    "tier": {
      "type": "string",
      "description": "Constellation visibility tier for this ritual (policy/registry view).",
      "enum": [
        "Tier1Public",
        "Tier2Internal",
        "Tier3Vault",
        "Tier4Underground"
      ]
    },
    "safety_tier": {
      "type": "string",
      "description": "Safety tier this ritual is intended for.",
      "enum": [
        "standard",
        "mature",
        "research"
      ]
    },
    "deadledgerRef": {
      "type": ["string", "null"],
      "description": "Optional Dead-Ledger attestation reference for high-intensity or gated rituals. CI requires this to be non-null for high-intensity bands."
    },
    "intensityBand": {
      "type": "integer",
      "description": "Coarse intensity band (0–10) used for governance and Dead-Ledger requirements.",
      "minimum": 0,
      "maximum": 10
    },

    "ritual_profile": {
      "type": "object",
      "description": "Ritual profile describing qualitative pacing and primary use.",
      "additionalProperties": false,
      "required": [
        "name",
        "kind",
        "description",
        "target_stage"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 3,
          "maxLength": 120
        },
        "kind": {
          "type": "string",
          "description": "Ritual profile kind, used by Directors and PCG.",
          "enum": [
            "SlowBurnThresholdCorridor",
            "ConfrontationTileCluster",
            "InvestigationSpiral",
            "EvidenceDrift",
            "AftermathEcho",
            "ResidualSeep",
            "Custom"
          ]
        },
        "description": {
          "type": "string",
          "maxLength": 4000
        },
        "target_stage": {
          "type": "string",
          "description": "Primary stage this ritual is designed to emphasize.",
          "enum": [
            "stage1_probe",
            "stage2_evidence",
            "stage3_confrontation",
            "stage4_aftermath",
            "stage5_residual"
          ]
        }
      }
    },

    "applies_to": {
      "type": "object",
      "description": "Selectors that determine which Seeds this ritual attaches to.",
      "additionalProperties": false,
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "description": "How this ritual binds to Seeds.",
          "enum": [
            "by_seed_ids",
            "by_seed_tags",
            "by_region_ids",
            "by_policy_profile"
          ]
        },
        "seed_ids": {
          "type": "array",
          "description": "Explicit Seed IDs to which this ritual applies.",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_.-]{8,64}$"
          }
        },
        "seed_tags": {
          "type": "array",
          "description": "Seed tags (stage/biome/persona/etc.) this ritual should attach to.",
          "items": {
            "type": "string",
            "maxLength": 64
          }
        },
        "region_ids": {
          "type": "array",
          "description": "Region IDs whose Seeds are subject to this ritual.",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_.-]{8,64}$"
          }
        },
        "policy_profile_id": {
          "type": "string",
          "description": "Optional policy envelope ID; Seeds bound to this policy are governed by this ritual.",
          "maxLength": 128
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "by_seed_ids"
              }
            }
          },
          "then": {
            "required": [
              "seed_ids"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "mode": {
                "const": "by_seed_tags"
              }
            }
          },
          "then": {
            "required": [
              "seed_tags"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "mode": {
                "const": "by_region_ids"
              }
            }
          },
          "then": {
            "required": [
              "region_ids"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "mode": {
                "const": "by_policy_profile"
              }
            }
          },
          "then": {
            "required": [
              "policy_profile_id"
            ]
          }
        }
      ]
    },

    "stageBindings": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/stageBinding"
      },
      "minItems": 1
    },

    "stageMetricBands": {
      "type": "object",
      "description": "Per-stage minimum entertainment bands (UEC, EMD, STCI, CDL, ARR). STCI_min and CDL_min are expected to be monotone Probe → Evidence → Confrontation, and ARR_min must not fall below the Charter minimum. These cross-field constraints are enforced by tools/lint-seed-ritual-stage-bands.py.",
      "additionalProperties": false,
      "required": [
        "probe",
        "evidence",
        "confrontation",
        "aftermath",
        "residual"
      ],
      "properties": {
        "probe": {
          "$ref": "#/definitions/stageMetricBand"
        },
        "evidence": {
          "$ref": "#/definitions/stageMetricBand"
        },
        "confrontation": {
          "$ref": "#/definitions/stageMetricBand"
        },
        "aftermath": {
          "$ref": "#/definitions/stageMetricBand"
        },
        "residual": {
          "$ref": "#/definitions/stageMetricBand"
        }
      }
    },

    "stageIntensityEnvelopes": {
      "type": "object",
      "description": "Per-stage audiovisual intensity bands. Probe must have non-zero minima when any Probe intensity profile is defined; enforced by tools/lint-seed-ritual-stage-bands.py.",
      "additionalProperties": false,
      "required": [
        "probe",
        "evidence",
        "confrontation",
        "aftermath",
        "residual"
      ],
      "properties": {
        "probe": {
          "$ref": "#/definitions/intensityStage"
        },
        "evidence": {
          "$ref": "#/definitions/intensityStage"
        },
        "confrontation": {
          "$ref": "#/definitions/intensityStage"
        },
        "aftermath": {
          "$ref": "#/definitions/intensityStage"
        },
        "residual": {
          "$ref": "#/definitions/intensityStage"
        }
      }
    },

    "min_intensity_envelope": {
      "type": "object",
      "description": "Coarse-grained minimum audiovisual intensity floors per stage, expressed as normalized audio/visual presence. Engines may exceed these floors but must never drop below them once a Seed is fired under this ritual.",
      "additionalProperties": false,
      "required": [
        "probe",
        "evidence",
        "confrontation",
        "aftermath",
        "residual"
      ],
      "properties": {
        "probe": {
          "$ref": "#/definitions/minIntensityStage"
        },
        "evidence": {
          "$ref": "#/definitions/minIntensityStage"
        },
        "confrontation": {
          "$ref": "#/definitions/minIntensityStageWithDet"
        },
        "aftermath": {
          "$ref": "#/definitions/minIntensityStage"
        },
        "residual": {
          "$ref": "#/definitions/minIntensityStage"
        }
      }
    },

    "gore_assembly_profile": {
      "type": "object",
      "description": "Policy over gore/violence assembly; references implication-only gore assembly styles and GXI ranges, never explicit content.",
      "additionalProperties": false,
      "required": [
        "allowed_style_ids",
        "forbidden_style_ids",
        "max_gxi_by_consent_tier"
      ],
      "properties": {
        "allowed_style_ids": {
          "type": "array",
          "description": "Allowed goreassemblystyle identifiers.",
          "items": {
            "type": "string",
            "maxLength": 128
          }
        },
        "forbidden_style_ids": {
          "type": "array",
          "description": "Explicitly forbidden goreassemblystyle identifiers for this ritual.",
          "items": {
            "type": "string",
            "maxLength": 128
          }
        },
        "max_gxi_by_consent_tier": {
          "type": "object",
          "description": "Maximum GXI values allowed per consent tier, enforced by governance modules.",
          "additionalProperties": false,
          "required": [
            "standard",
            "mature",
            "research"
          ],
          "properties": {
            "standard": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            },
            "mature": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            },
            "research": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            }
          }
        },
        "requires_implication_only": {
          "type": "boolean",
          "description": "If true, only implication-only styles may be used under this ritual (no explicit anatomical focus).",
          "default": true
        }
      }
    },

    "runtime_hints": {
      "type": "object",
      "description": "Optional hints for Director/PCG modules on how to use this ritual.",
      "additionalProperties": false,
      "properties": {
        "preferred_modules": {
          "type": "array",
          "description": "Modules expected to enforce this ritual (e.g., SeedGeneratorModule10, DirectorCore).",
          "items": {
            "type": "string",
            "maxLength": 128
          }
        },
        "allow_downtier_if_unmet": {
          "type": "boolean",
          "description": "If false, Seeds that cannot meet ritual floors must be rejected, not softened.",
          "default": false
        },
        "telemetry_profile_id": {
          "type": "string",
          "description": "Optional telemetry/entertainment-metrics profile used to validate ritual performance.",
          "maxLength": 128
        }
      }
    }
  },

  "definitions": {
    "stageBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage",
        "seedId"
      ],
      "properties": {
        "stage": {
          "type": "string",
          "enum": [
            "probe",
            "evidence",
            "confrontation",
            "aftermath",
            "residual"
          ]
        },
        "seedId": {
          "type": "string"
        },
        "weight": {
          "type": "number"
        },
        "priority": {
          "type": "integer"
        }
      }
    },

    "stageMetricBand": {
      "type": "object",
      "description": "Normalized entertainment metric floors for a single stage. Cross-stage STCI/CDL monotonicity and Charter-aligned ARR_min are enforced by tools/lint-seed-ritual-stage-bands.py.",
      "additionalProperties": false,
      "required": [
        "UEC_min",
        "EMD_min",
        "STCI_min",
        "CDL_min",
        "ARR_min",
        "ARR_max"
      ],
      "properties": {
        "UEC_min": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "EMD_min": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "STCI_min": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "CDL_min": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "ARR_min": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Charter requires ARR_min to be >= global minimum (see tools/lint-seed-ritual-stage-bands.py for enforcement)."
        },
        "ARR_max": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },

    "intensityStage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "audioIntensity",
        "visualIntensity"
      ],
      "properties": {
        "audioIntensity": {
          "$ref": "#/definitions/minMax"
        },
        "visualIntensity": {
          "$ref": "#/definitions/minMax"
        },
        "hapticIntensity": {
          "$ref": "#/definitions/minMax"
        },
        "bciIntensityHint": {
          "$ref": "#/definitions/minMax"
        }
      }
    },

    "minMax": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min",
        "max"
      ],
      "properties": {
        "min": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "max": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },

    "minIntensityStage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min_audio_pressure",
        "min_visual_presence"
      ],
      "properties": {
        "min_audio_pressure": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "min_visual_presence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },

    "minIntensityStageWithDet": {
      "allOf": [
        {
          "$ref": "#/definitions/minIntensityStage"
        },
        {
          "type": "object",
          "properties": {
            "max_DET_delta": {
              "type": "number",
              "minimum": 0.0
            }
          }
        }
      ]
    }
  }
}
