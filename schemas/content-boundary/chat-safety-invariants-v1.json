{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://horror.place/schemas/content-boundary/chat-safety-invariants-v1.json",
  "title": "ChatSafetyInvariants",
  "description": "Physics layer defining 16 spine invariants across 3 enforcement classes, governing all AI-chat horror outputs. Implements 5-phase evaluation with short-circuit semantics and 3-level violation escalation. Aligns with Content Boundary & Policy Module (Module 4) and CHAT_DIRECTOR governance spine.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schemaRef",
    "objectKind",
    "version",
    "evaluationPipeline",
    "invariantCatalog",
    "escalationMatrix",
    "prismMeta"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^cinv-[a-z0-9]{6,12}$",
      "description": "Stable identifier for this safety invariants configuration."
    },
    "schemaRef": {
      "type": "string",
      "const": "chat-safety-invariants.v1",
      "description": "Schema version identifier for validator binding."
    },
    "objectKind": {
      "type": "string",
      "const": "chatSafetyInvariants",
      "description": "Object kind for CHAT_DIRECTOR routing and manifest validation."
    },
    "version": {
      "type": "string",
      "pattern": "^v1\\.[0-9]+\\.[0-9]+$",
      "description": "Semantic version; minor bumps add invariants, patch bumps adjust thresholds."
    },
    "evaluationPipeline": {
      "type": "object",
      "description": "Ordered 5-phase evaluation pipeline with short-circuit semantics. Failure in any phase halts downstream processing based on violation class.",
      "additionalProperties": false,
      "required": ["phaseOrder", "shortCircuitRules"],
      "properties": {
        "phaseOrder": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "absolute_precheck",
              "session_context_check",
              "consent_gate",
              "budget_gate",
              "output_gate"
            ]
          },
          "description": "Strict evaluation sequence. All ABSOLUTE invariants are checked first; any violation triggers immediate termination.",
          "minItems": 5,
          "maxItems": 5
        },
        "shortCircuitRules": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ABSOLUTE", "CONSENT_GATED", "BUDGET_GATED"],
          "properties": {
            "ABSOLUTE": {
              "type": "object",
              "additionalProperties": false,
              "required": ["haltPipeline", "logLevel", "deadLedgerFlag"],
              "properties": {
                "haltPipeline": { "type": "boolean", "const": true },
                "logLevel": { "type": "string", "const": "critical" },
                "deadLedgerFlag": { "type": "boolean", "const": true, "description": "Mandatory attestation for ABSOLUTE violations." }
              }
            },
            "CONSENT_GATED": {
              "type": "object",
              "additionalProperties": false,
              "required": ["haltPipeline", "fallbackAction"],
              "properties": {
                "haltPipeline": { "type": "boolean", "const": false },
                "fallbackAction": { "type": "string", "enum": ["downshift_tier", "soften_output", "refuse"] }
              }
            },
            "BUDGET_GATED": {
              "type": "object",
              "additionalProperties": false,
              "required": ["haltPipeline", "fallbackAction"],
              "properties": {
                "haltPipeline": { "type": "boolean", "const": false },
                "fallbackAction": { "type": "string", "enum": ["clamp_intensity", "trigger_cooldown", "downshift_tier"] }
              }
            }
          }
        }
      }
    },
    "invariantCatalog": {
      "type": "array",
      "description": "Array of 16 spine invariants mapped to enforcement classes, phases, and metric thresholds.",
      "minItems": 16,
      "maxItems": 16,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["invariantId", "enforcementClass", "evaluationPhase", "spineMetrics", "actionOnViolation", "description"],
        "properties": {
          "invariantId": {
            "type": "string",
            "pattern": "^SAF-[0-9]{3}$"
          },
          "enforcementClass": {
            "type": "string",
            "enum": ["ABSOLUTE", "CONSENT_GATED", "BUDGET_GATED"]
          },
          "evaluationPhase": {
            "type": "string",
            "enum": [
              "absolute_precheck",
              "session_context_check",
              "consent_gate",
              "budget_gate",
              "output_gate"
            ]
          },
          "spineMetrics": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["CIC", "MDI", "AOS", "RRM", "FCF", "SPR", "RWF", "DET", "HVF", "LSG", "SHCI", "CDL", "ARR"]
            },
            "description": "Core spine metrics this invariant monitors or constrains."
          },
          "thresholds": {
            "type": "object",
            "additionalProperties": false,
            "description": "Optional numeric or categorical bounds for evaluation.",
            "properties": {
              "minTier": { "type": "string", "enum": ["CHILD", "TEEN", "MATURE", "RESEARCH"] },
              "maxIntensityDelta": { "type": "number", "minimum": 0 },
              "reserveFloorPercent": { "type": "number", "minimum": 0, "maximum": 100 },
              "consentRequirement": { "type": "string" }
            }
          },
          "actionOnViolation": {
            "type": "string",
            "enum": ["hard_deny", "soften_output", "downshift_tier", "clamp_intensity", "trigger_cooldown", "log_and_monitor"]
          },
          "description": {
            "type": "string",
            "maxLength": 512
          }
        }
      }
    },
    "escalationMatrix": {
      "type": "object",
      "description": "3-level violation escalation model governing system response over rolling windows.",
      "additionalProperties": false,
      "required": ["observe", "throttle", "halt"],
      "properties": {
        "observe": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maxOccurrencesPerWindow", "windowMinutes", "action"],
          "properties": {
            "maxOccurrencesPerWindow": { "type": "integer", "minimum": 1 },
            "windowMinutes": { "type": "integer", "minimum": 1 },
            "action": { "type": "string", "const": "log_to_telemetry_and_emit_warning" }
          }
        },
        "throttle": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maxOccurrencesPerWindow", "cooldownMinutes", "action"],
          "properties": {
            "maxOccurrencesPerWindow": { "type": "integer", "minimum": 1 },
            "cooldownMinutes": { "type": "integer", "minimum": 5, "maximum": 60 },
            "action": { "type": "string", "const": "force_downshift_and_suspend_high_det_content" }
          }
        },
        "halt": {
          "type": "object",
          "additionalProperties": false,
          "required": ["triggers", "action"],
          "properties": {
            "triggers": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["ANY_ABSOLUTE_VIOLATION", "REPEATED_CONSENT_BREACHES", "BUDGET_RESERVE_EXHAUSTION"]
              }
            },
            "action": {
              "type": "string",
              "const": "terminate_session_and_emit_incident_to_dead_ledger"
            }
          }
        }
      }
    },
    "prismMeta": {
      "type": "object",
      "description": "Standard prismMeta block for schema spine alignment; shape defined in prismMeta.v1.json.",
      "additionalProperties": true,
      "properties": {
        "author": { "type": "string" },
        "reviewed": { "type": "array", "items": { "type": "string" } },
        "governanceRef": { "type": "string" }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "invariantCatalog": { "contains": { "properties": { "invariantId": { "const": "SAF-001" } } } } }
      },
      "then": {
        "properties": {
          "invariantCatalog": {
            "contains": {
              "properties": { "invariantId": { "const": "SAF-001" }, "enforcementClass": { "const": "ABSOLUTE" }, "evaluationPhase": { "const": "absolute_precheck" }, "actionOnViolation": { "const": "hard_deny" } }
            }
          }
        }
      }
    }
  ]
}
