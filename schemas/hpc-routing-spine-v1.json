    "overview": "Routing spine v1 covering moodContract, eventContract, regionContractCard, and seedContractCard for Tier-1 and Tier-2 repos.",
    "objectKindNotes": {
      "moodContract": {
        "summary": "Design-level mood contracts that define invariant and metric bands for atmosphere, authored in Tier-1 and consumed in Tier-2 vaults.",
        "usage": "Use for schema-first definition of moods with no raw horror content in Tier-1; Tier-2 routes consume these contracts when binding to regions, tiles, and events."
      },
      "eventContract": {
        "summary": "Region-bound story events that couple invariants, metrics, and SHCI to regions and personas.",
        "usage": "Use in Atrocity-Seeds to define hero events and gating logic driven by invariant and metric bands."
      },
      "regionContractCard": {
        "summary": "Numeric design surface for hero regions; canonical home for region-level invariant and metric bands.",
        "usage": "Author in Atrocity-Seeds to set CIC/DET/SHCI and UEC/ARR targets for region experiences."
      },
      "seedContractCard": {
        "summary": "Procedural story seeds that glue regions, events, personas, and history together.",
        "usage": "Use to define Outer/Threshold/Locus/Rupture/Fallout seeds with stage-aware UEC/ARR/CDL profiles."
      }
    }
