{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema:HorrorPlace/Constellation-Contracts/mechanic_contract_timing_params_v1.json",
  "title": "HorrorPlace Mechanic Timing Parameters v1",
  "description": "Contract-first timing parameter schema for systemic timing mechanics (e.g. CoyoteTime, RuleOfThree, AdaptiveDamage).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "mechanicKind",
    "policyEnvelopeId",
    "regionContractId",
    "safetyTier",
    "intensityBand",
    "detBand",
    "arrBand",
    "uecBand",
    "parameterFamilies"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable timing-params contract id, e.g. systemicTiming.coyote.standard.v1."
    },
    "version": {
      "type": "string",
      "description": "Semantic version.",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "mechanicKind": {
      "type": "string",
      "description": "Mechanic family this timing contract applies to.",
      "enum": [
        "CoyoteTime",
        "RuleOfThree",
        "AdaptiveDamage",
        "Other"
      ]
    },
    "policyEnvelopeId": {
      "type": "string",
      "description": "Parent policy envelope id for narrowing checks."
    },
    "regionContractId": {
      "type": "string",
      "description": "Region contract this timing profile is narrowed under."
    },
    "safetyTier": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3,
      "description": "Safety tier (1–3) aligned with constellation doctrine."
    },
    "intensityBand": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10,
      "description": "Nominal intensity band for this mechanic."
    },
    "detBand": {
      "$ref": "#/$defs/rangeDet"
    },
    "arrBand": {
      "$ref": "#/$defs/range01"
    },
    "uecBand": {
      "$ref": "#/$defs/range01"
    },
    "parameterFamilies": {
      "type": "object",
      "description": "Mechanic-specific parameter groups.",
      "additionalProperties": false,
      "properties": {
        "coyoteTime": {
          "$ref": "#/$defs/coyoteParams"
        },
        "ruleOfThree": {
          "$ref": "#/$defs/ruleOfThreeParams"
        },
        "adaptiveDamage": {
          "$ref": "#/$defs/adaptiveDamageParams"
        }
      }
    }
  },
  "$defs": {
    "range01": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "max": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      }
    },
    "rangeDet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": { "type": "number", "minimum": 0.0, "maximum": 10.0 },
        "max": { "type": "number", "minimum": 0.0, "maximum": 10.0 }
      }
    },
    "coyoteParams": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "weightDet",
        "weightArr",
        "baseProbability",
        "maxProbability",
        "detNormBand",
        "arrNormBand"
      ],
      "properties": {
        "weightDet": { "type": "number", "minimum": 0.0, "maximum": 10.0 },
        "weightArr": { "type": "number", "minimum": -10.0, "maximum": 0.0 },
        "baseProbability": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "maxProbability": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "detNormBand": { "$ref": "#/$defs/rangeDet" },
        "arrNormBand": { "$ref": "#/$defs/range01" }
      }
    },
    "ruleOfThreeParams": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "earlyForgivenessProbability",
        "latePunishProbability",
        "arrFloor",
        "detNormBand"
      ],
      "properties": {
        "earlyForgivenessProbability": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "latePunishProbability": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "arrFloor": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "detNormBand": { "$ref": "#/$defs/rangeDet" }
      }
    },
    "adaptiveDamageParams": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minMultiplier",
        "maxMultiplier",
        "weightDet",
        "weightArr",
        "detNormBand",
        "arrNormBand"
      ],
      "properties": {
        "minMultiplier": { "type": "number", "minimum": 0.0, "maximum": 5.0 },
        "maxMultiplier": { "type": "number", "minimum": 0.0, "maximum": 5.0 },
        "weightDet": { "type": "number", "minimum": 0.0, "maximum": 10.0 },
        "weightArr": { "type": "number", "minimum": -10.0, "maximum": 0.0 },
        "detNormBand": { "$ref": "#/$defs/rangeDet" },
        "arrNormBand": { "$ref": "#/$defs/range01" }
      }
    }
  }
}
