{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema:HorrorPlace/Constellation-Contracts/mechanic_contract_timing_params_v1.json",
  "title": "HorrorPlace Mechanic Timing Parameters v1",
  "description": "Contract-first timing parameter schema for systemic timing mechanics (e.g., CoyoteTime, RuleOfThree, AdaptiveDamage), reusing invariant and entertainment metric range definitions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "mechanicKind",
    "policyEnvelopeId",
    "regionContractId",
    "safetyTier",
    "intensityBand",
    "detBand",
    "arrBand",
    "uecBand",
    "parameterFamilies"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable timing-params contract id, e.g. systemicTiming.coyote.standard.v1."
    },
    "version": {
      "type": "string",
      "description": "Semantic version.",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "mechanicKind": {
      "type": "string",
      "description": "Mechanic family this timing contract applies to.",
      "enum": [
        "CoyoteTime",
        "RuleOfThree",
        "AdaptiveDamage",
        "Other"
      ]
    },
    "policyEnvelopeId": {
      "type": "string",
      "description": "Parent policy envelope id for narrowing checks."
    },
    "regionContractId": {
      "type": "string",
      "description": "Region contract this timing profile is narrowed under."
    },
    "safetyTier": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3,
      "description": "Safety tier (1–3) aligned with constellation doctrine."
    },
    "intensityBand": {
      "type": "string",
      "description": "High-level intensity band for this timing profile.",
      "enum": ["mild", "moderate", "severe", "adult"]
    },

    "detBand": {
      "description": "DET band (0–10) for this mechanic, via invariants_v1 definition.",
      "$ref": "schemas/invariants_v1.json#/$defs/detBand"
    },

    "arrBand": {
      "description": "ARR band (0–1) for this mechanic, via entertainment_metrics_v1 definition.",
      "$ref": "schemas/entertainment_metrics_v1.json#/$defs/metricBand"
    },

    "uecBand": {
      "description": "UEC band (0–1) for this mechanic, via entertainment_metrics_v1 definition.",
      "$ref": "schemas/entertainment_metrics_v1.json#/$defs/metricBand"
    },

    "parameterFamilies": {
      "type": "object",
      "description": "Mechanic-specific parameter groups.",
      "additionalProperties": false,
      "properties": {
        "coyoteTime": {
          "$ref": "#/$defs/coyoteParams"
        },
        "ruleOfThree": {
          "$ref": "#/$defs/ruleOfThreeParams"
        },
        "adaptiveDamage": {
          "$ref": "#/$defs/adaptiveDamageParams"
        }
      }
    }
  },

  "$defs": {
    "coyoteParams": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "weightDet",
        "weightArr",
        "baseProbability",
        "maxProbability",
        "detNormBand",
        "arrNormBand"
      ],
      "properties": {
        "weightDet": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 10.0,
          "description": "Scaling weight for normalized DET."
        },
        "weightArr": {
          "type": "number",
          "minimum": -10.0,
          "maximum": 0.0,
          "description": "Scaling weight for normalized ARR (typically negative to avoid over-resolving)."
        },
        "baseProbability": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Base coyote time grant probability."
        },
        "maxProbability": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Upper bound on coyote time grant probability."
        },

        "detNormBand": {
          "description": "DET normalization band, reusing DET range from invariants_v1.",
          "$ref": "schemas/invariants_v1.json#/$defs/detBand"
        },

        "arrNormBand": {
          "description": "ARR normalization band, reusing metric band from entertainment_metrics_v1.",
          "$ref": "schemas/entertainment_metrics_v1.json#/$defs/metricBand"
        }
      }
    },

    "ruleOfThreeParams": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "earlyForgivenessProbability",
        "latePunishProbability",
        "arrFloor",
        "detNormBand"
      ],
      "properties": {
        "earlyForgivenessProbability": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Base probability to forgive early failures (<3 attempts)."
        },
        "latePunishProbability": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Base probability to punish after repeated failures (>=3 attempts)."
        },
        "arrFloor": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Minimum ARR the mechanic should maintain; below this, punishment is reduced."
        },

        "detNormBand": {
          "description": "DET normalization band for this mechanic.",
          "$ref": "schemas/invariants_v1.json#/$defs/detBand"
        }
      }
    },

    "adaptiveDamageParams": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minMultiplier",
        "maxMultiplier",
        "weightDet",
        "weightArr",
        "detNormBand",
        "arrNormBand"
      ],
      "properties": {
        "minMultiplier": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 5.0,
          "description": "Lower bound for damage multiplier."
        },
        "maxMultiplier": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 5.0,
          "description": "Upper bound for damage multiplier."
        },
        "weightDet": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 10.0,
          "description": "Scaling weight for normalized DET."
        },
        "weightArr": {
          "type": "number",
          "minimum": -10.0,
          "maximum": 0.0,
          "description": "Scaling weight for normalized ARR (often negative to preserve ambiguity)."
        },

        "detNormBand": {
          "description": "DET normalization band for adaptive damage.",
          "$ref": "schemas/invariants_v1.json#/$defs/detBand"
        },

        "arrNormBand": {
          "description": "ARR normalization band for adaptive damage.",
          "$ref": "schemas/entertainment_metrics_v1.json#/$defs/metricBand"
        }
      }
    }
  }
}
