{
  "$id": "https://horror.place/constellation/schemas/chatdirector-errors-v1.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "chatDirectorErrorv1",
  "type": "object",
  "additionalProperties": false,
  "required": ["code", "severity", "path", "phase", "objectKind", "message"],
  "properties": {
    "code": { "type": "string" },
    "severity": { "type": "string", "enum": ["info", "warning", "error"] },
    "path": { "type": "string" },
    "phase": { "type": "string" },
    "objectKind": { "type": "string" },
    "invariantOrMetric": { "type": "string" },
    "message": { "type": "string" },
    "hint": { "type": "string" },
    "docRef": { "type": "string" }
  }
}
