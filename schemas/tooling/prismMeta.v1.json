{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://horrorplace.constellation/schemas/tooling/prismMeta.v1.json",
  "title": "Prism Metadata v1.0.0",
  "description": "Machine-readable metadata for bidirectional validation, dependency tracking, and linkage in AI-generated artifacts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generatedBy",
    "linkage",
    "dependencies",
    "validationPropagation",
    "prismHash"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0.0",
      "description": "prismMeta schema version."
    },
    "generatedBy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agentId",
        "agentProfileRef",
        "timestamp"
      ],
      "properties": {
        "agentId": {
          "type": "string",
          "description": "Identifier of the AI agent or tool that created this artifact."
        },
        "agentProfileRef": {
          "type": "string",
          "format": "uri",
          "description": "Reference to the agentProfile schema governing the generating agent."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "UTC timestamp of generation."
        }
      }
    },
    "linkage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targetRepo",
        "targetPath",
        "schemaRef",
        "tier"
      ],
      "properties": {
        "targetRepo": {
          "type": "string",
          "description": "Exact repository where this artifact belongs."
        },
        "targetPath": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9/_\\-\\.]+\\.(json|ndjson|yml|md)$",
          "description": "Exact file path within targetRepo."
        },
        "schemaRef": {
          "type": "string",
          "format": "uri",
          "description": "Canonical JSON Schema $id this artifact conforms to."
        },
        "tier": {
          "type": "string",
          "enum": [
            "public",
            "vault",
            "lab"
          ],
          "description": "Access tier for this artifact."
        }
      }
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "invariants": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "CIC",
              "AOS",
              "DET",
              "SHCI"
            ]
          },
          "description": "List of invariants this artifact depends on or affects."
        },
        "metrics": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "UEC",
              "EMD",
              "STCI",
              "CDL",
              "ARR"
            ]
          },
          "description": "List of metrics this artifact monitors or targets."
        },
        "contracts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of other contract IDs this artifact relies upon."
        },
        "registryIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z]{3,4}-[A-Z0-9]{3,6}-\\d{4}$"
          },
          "description": "List of registry entry IDs referenced by this artifact."
        }
      }
    },
    "validationPropagation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "onSchemaChange",
        "onInvariantDrift",
        "notifyRepos"
      ],
      "properties": {
        "onSchemaChange": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "CI jobs or tools to trigger if the referenced schema changes."
        },
        "onInvariantDrift": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Actions to take if invariant values drift from canonical ranges."
        },
        "notifyRepos": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Repositories to alert when this artifact is updated or invalidated."
        }
      }
    },
    "prismHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "Cryptographic hash of the artifact content for integrity verification."
    }
  }
}
