{
  "$id": "https://horrorplace.org/schemas/tooling/ai-authoring-request-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Authoring Request v1",
  "description": "Normalized request envelope for AI- or human-initiated authoring actions routed through CHATDIRECTOR.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestId",
    "sessionId",
    "actorId",
    "intent",
    "objectKind",
    "phase",
    "tier",
    "targetRepo",
    "schemaRef",
    "identity",
    "preferences"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^1\\.0\\.0$"
    },
    "requestId": {
      "type": "string",
      "description": "Unique identifier for this authoring request."
    },
    "sessionId": {
      "type": "string",
      "description": "Join key linking this request to editor telemetry, PCG, and governance streams."
    },
    "actorId": {
      "type": "string",
      "description": "Identifier for the human editor or AI agent initiating this request."
    },
    "intent": {
      "type": "string",
      "description": "Natural language summary of what the actor wants to achieve.",
      "minLength": 1,
      "maxLength": 4096
    },
    "objectKind": {
      "type": "string",
      "enum": [
        "regionContractCard",
        "seedContractCard",
        "moodContract",
        "eventContract"
      ]
    },
    "phase": {
      "type": "string",
      "enum": [
        "PHASE0_DISCOVERY",
        "PHASE1_SCOPING",
        "PHASE2_CONTRACTS",
        "PHASE3_BINDINGS",
        "PHASE4_RUNTIME"
      ]
    },
    "tier": {
      "type": "string",
      "enum": [
        "TIER1_PUBLIC",
        "TIER2_MATURE",
        "TIER3_RESEARCH"
      ]
    },
    "targetRepo": {
      "type": "string",
      "description": "Canonical repository name as declared in repo-manifest.hpc.*.json."
    },
    "schemaRef": {
      "type": "string",
      "description": "Canonical $id of the target contract schema."
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "regionId",
        "seedId",
        "descriptorId",
        "consentTier",
        "routerStateId",
        "selectorPatternId",
        "sessionMetricsEnvelopeId"
      ],
      "properties": {
        "regionId": {
          "type": "string"
        },
        "seedId": {
          "type": "string"
        },
        "descriptorId": {
          "type": "string"
        },
        "consentTier": {
          "type": "string",
          "enum": [
            "ACTIVE_CHILD",
            "ACTIVE_TEEN",
            "ACTIVE_MATURE"
          ]
        },
        "routerStateId": {
          "type": "string"
        },
        "selectorPatternId": {
          "type": "string"
        },
        "sessionMetricsEnvelopeId": {
          "type": "string"
        }
      }
    },
    "preferences": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metricPriorities",
        "styleHints"
      ],
      "properties": {
        "metricPriorities": {
          "type": "array",
          "description": "Optional metric weighting preferences for this request.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "metric",
              "priority",
              "direction"
            ],
            "properties": {
              "metric": {
                "type": "string",
                "enum": [
                  "UEC",
                  "EMD",
                  "STCI",
                  "CDL",
                  "ARR"
                ]
              },
              "priority": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5
              },
              "direction": {
                "type": "string",
                "enum": [
                  "MAXIMIZE",
                  "MINIMIZE",
                  "TARGET_BAND"
                ]
              }
            }
          }
        },
        "styleHints": {
          "type": "array",
          "description": "Non-binding stylistic hints (e.g., artstyle IDs) that downstream tools may consider.",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "fieldConfidence": {
      "type": "object",
      "description": "Optional per-field confidence scores from AI, used to guide clarification prompts.",
      "additionalProperties": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      }
    },
    "telemetryContext": {
      "type": "object",
      "description": "Optional aggregate telemetry snapshot to inform skeleton generation.",
      "additionalProperties": false,
      "properties": {
        "recentUEC": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "recentARR": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "recentCDL": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "playSessions": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "generationHints": {
      "type": "object",
      "description": "Hints produced by CHATDIRECTOR during planning, consumed by AI during generation.",
      "additionalProperties": false,
      "properties": {
        "skeletonVariant": {
          "type": "string",
          "enum": [
            "MINIMAL",
            "TUTORIAL",
            "PRODUCTION"
          ]
        },
        "notes": {
          "type": "string",
          "maxLength": 4096
        }
      }
    }
  }
}
