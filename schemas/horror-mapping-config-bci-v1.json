{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://horror.place/schemas/horror-mapping-config-bci-v1.json",
  "title": "HorrorMappingConfig.BCI.v1",
  "description": "Canonical configuration that maps BCI metrics and invariants to horror-facing control channels via a constrained set of mapping families and safety-checked guardrails.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "schemaref",
    "schemaVersion",
    "policyId",
    "inputs",
    "channels",
    "profiles",
    "safety",
    "lifecycle",
    "features",
    "inputDomain"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable mapping-config identifier, e.g. HorrorMappingConfig.BCI.SprintTunnelFlash.v1."
    },
    "version": {
      "type": "string",
      "description": "Semantic version for this mapping config, e.g. 1.0.0."
    },
    "schemaref": {
      "type": "string",
      "const": "schemas/bci/horror-mapping-config-bci-v1.json",
      "description": "Local schema path for CI and toolchains."
    },
    "schemaVersion": {
      "type": "string",
      "const": "HorrorMappingConfig.BCI.v1",
      "description": "Explicit schema version identifier for this binding."
    },
    "tier": {
      "type": "string",
      "enum": [ "research", "standard", "mature" ],
      "description": "Legacy safety tier for this mapping profile; superseded by lifecycle.tier but retained for backward compatibility."
    },
    "policyId": {
      "type": "string",
      "description": "Reference to a bci-intensity-policy artifact that sets global caps and constraints."
    },
    "inputs": {
      "type": "object",
      "description": "Declaration of which BCI metrics, invariants, and bcistate fields this config may read.",
      "additionalProperties": false,
      "required": [ "metrics", "invariants", "bcistate" ],
      "properties": {
        "metrics": {
          "type": "array",
          "description": "Known normalized metric inputs drawn from bci-metrics-envelope-v2; typically 0..1.",
          "items": {
            "type": "string",
            "enum": [
              "fearIndex",
              "calmScore",
              "stressScore",
              "attentionFocus",
              "UEC",
              "EMD",
              "STCI",
              "CDL",
              "ARR",
              "DET"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "invariants": {
          "type": "array",
          "description": "Invariant inputs from the invariants/metrics spine.",
          "items": {
            "type": "string",
            "enum": [
              "CIC",
              "AOS",
              "HVF",
              "LSG",
              "SHCI",
              "RRM",
              "MDI",
              "SPR",
              "RWF"
            ]
          },
          "minItems": 0,
          "uniqueItems": true
        },
        "bcistate": {
          "type": "object",
          "description": "Optional bcistate inputs coming from bcicore-intensity and related envelopes.",
          "additionalProperties": false,
          "properties": {
            "useIntensityMode": {
              "type": "boolean",
              "description": "Whether bcicore intensity mode CALM, FOCUSED, TENSE, OVERLOADED is available as a condition."
            },
            "useFearBand": {
              "type": "boolean",
              "description": "Whether bcistate.fearBand LOW, MED, HIGH is used for gating."
            },
            "useOverloadFlag": {
              "type": "boolean",
              "description": "Whether bcistate.overloadFlag is used in conditions."
            }
          }
        }
      }
    },
    "channels": {
      "type": "object",
      "description": "Declaration of horror-facing control channels that this mapping config may drive.",
      "additionalProperties": false,
      "properties": {
        "tension": {
          "type": "object",
          "description": "Normalized tension signal in 0..1.",
          "required": [ "enabled", "min", "max" ],
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "min": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            "max": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
          }
        },
        "sprintMul": {
          "type": "object",
          "description": "Sprint multiplier affecting player movement speed.",
          "required": [ "enabled", "min", "max" ],
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "min": { "type": "number" },
            "max": { "type": "number" }
          }
        },
        "tunnelRadius": {
          "type": "object",
          "description": "Radius of tunnel vision mask.",
          "required": [ "enabled", "min", "max" ],
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "min": { "type": "number" },
            "max": { "type": "number" }
          }
        },
        "tunnelOpacity": {
          "type": "object",
          "description": "Opacity of tunnel vision mask.",
          "required": [ "enabled", "min", "max" ],
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "min": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            "max": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
          }
        },
        "flashlightJitterAmp": {
          "type": "object",
          "description": "Amplitude of flashlight jitter.",
          "required": [ "enabled", "min", "max" ],
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "min": { "type": "number" },
            "max": { "type": "number" }
          }
        },
        "flashlightJitterFreq": {
          "type": "object",
          "description": "Frequency of flashlight jitter.",
          "required": [ "enabled", "min", "max" ],
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "min": { "type": "number" },
            "max": { "type": "number" }
          }
        },
        "encounterSpawnMul": {
          "type": "object",
          "description": "Multiplier for encounter spawn rates.",
          "required": [ "enabled", "min", "max" ],
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "min": { "type": "number" },
            "max": { "type": "number" }
          }
        }
      }
    },
    "profiles": {
      "type": "array",
      "description": "Named mapping profiles grouping per-channel mappings and conditions.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [ "profileId", "channels", "mappings" ],
        "properties": {
          "profileId": {
            "type": "string",
            "description": "Local identifier for this profile, e.g. sprint-inhibition."
          },
          "channels": {
            "type": "array",
            "description": "Channels this profile drives.",
            "items": {
              "type": "string",
              "enum": [
                "tension",
                "sprintMul",
                "tunnelRadius",
                "tunnelOpacity",
                "flashlightJitterAmp",
                "flashlightJitterFreq",
                "encounterSpawnMul"
              ]
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "conditions": {
            "type": "object",
            "description": "Optional per-profile gating conditions.",
            "additionalProperties": false,
            "properties": {
              "minUEC": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
              "maxUEC": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
              "minARR": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
              "maxARR": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
              "minCDL": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
              "maxCDL": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
              "minSignalQuality": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
              "disableOnLowSignal": {
                "type": "boolean",
                "description": "Disable mapping when signalQuality falls below minSignalQuality."
              },
              "allowedIntensityModes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [ "CALM", "FOCUSED", "TENSE", "OVERLOADED" ]
                },
                "uniqueItems": true
              },
              "disableWhenOverloadFlag": {
                "type": "boolean",
                "description": "If true, this profile is disabled while bcistate.overloadFlag is true."
              }
            }
          },
          "mappings": {
            "type": "array",
            "description": "Per-channel mapping entries implementing this profile.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [ "mappingId", "channel", "family", "inputs", "params" ],
              "properties": {
                "mappingId": {
                  "type": "string",
                  "description": "Local identifier for this mapping entry."
                },
                "channel": {
                  "type": "string",
                  "description": "Output control channel this mapping drives.",
                  "enum": [
                    "tension",
                    "sprintMul",
                    "tunnelRadius",
                    "tunnelOpacity",
                    "flashlightJitterAmp",
                    "flashlightJitterFreq",
                    "encounterSpawnMul"
                  ]
                },
                "family": {
                  "type": "string",
                  "description": "Mapping family, matching a mathematically defined kernel implemented in Rust.",
                  "enum": [
                    "linear",
                    "sigmoid",
                    "piecewise",
                    "hysteresis",
                    "oscillatory",
                    "noise_augmented",
                    "metric_aware"
                  ]
                },
                "inputs": {
                  "type": "array",
                  "description": "Names of inputs used by this mapping; subset of declared inputs.metrics, invariants, and bcistate flags.",
                  "items": { "type": "string" },
                  "minItems": 1,
                  "uniqueItems": true
                },
                "params": {
                  "type": "object",
                  "description": "Family-specific parameter vector.",
                  "additionalProperties": false,
                  "properties": {
                    "linear": {
                      "type": "object",
                      "description": "Parameters for linear family y = a*x + b.",
                      "additionalProperties": false,
                      "properties": {
                        "a": { "type": "number" },
                        "b": { "type": "number" },
                        "yMin": { "type": "number" },
                        "yMax": { "type": "number" }
                      }
                    },
                    "sigmoid": {
                      "type": "object",
                      "description": "Parameters for logistic family S(x) = 1 / (1 + exp(-k*(x - x0))).",
                      "additionalProperties": false,
                      "properties": {
                        "k": { "type": "number" },
                        "x0": { "type": "number" },
                        "yMin": { "type": "number" },
                        "yMax": { "type": "number" }
                      }
                    },
                    "piecewise": {
                      "type": "object",
                      "description": "Parameters for piecewise/banded mappings.",
                      "additionalProperties": false,
                      "properties": {
                        "breakpoints": {
                          "type": "array",
                          "items": { "type": "number" },
                          "minItems": 1
                        },
                        "valuesLow": {
                          "type": "number",
                          "description": "Output value or slope in the lowest band."
                        },
                        "valuesMid": {
                          "type": "number",
                          "description": "Output value or slope in the middle band."
                        },
                        "valuesHigh": {
                          "type": "number",
                          "description": "Output value or slope in the highest band."
                        },
                        "yMin": { "type": "number" },
                        "yMax": { "type": "number" }
                      }
                    },
                    "hysteresis": {
                      "type": "object",
                      "description": "Parameters for hysteresis curves.",
                      "additionalProperties": false,
                      "properties": {
                        "rising": {
                          "type": "object",
                          "description": "Parameters for rising branch (may mirror linear/sigmoid).",
                          "additionalProperties": true
                        },
                        "falling": {
                          "type": "object",
                          "description": "Parameters for falling branch.",
                          "additionalProperties": true
                        },
                        "switchDelta": {
                          "type": "number",
                          "description": "Minimum change in input needed to switch branch."
                        },
                        "yMin": { "type": "number" },
                        "yMax": { "type": "number" }
                      }
                    },
                    "oscillatory": {
                      "type": "object",
                      "description": "Parameters for low-frequency oscillatory modulation y(t) = B_base + A * sin(2π f t + phi).",
                      "additionalProperties": false,
                      "properties": {
                        "base": { "type": "number" },
                        "amplitude": { "type": "number" },
                        "frequencyNorm": {
                          "type": "number",
                          "description": "Frequency in normalized units; mapped into a safe Hz band by engine.",
                          "minimum": 0.0,
                          "maximum": 1.0
                        },
                        "phase": { "type": "number" },
                        "yMin": { "type": "number" },
                        "yMax": { "type": "number" }
                      }
                    },
                    "noise_augmented": {
                      "type": "object",
                      "description": "Parameters for noise-augmented mappings y = C_base(x) + epsilon(t).",
                      "additionalProperties": false,
                      "properties": {
                        "baseFamily": {
                          "type": "string",
                          "enum": [ "linear", "sigmoid", "piecewise" ]
                        },
                        "baseParams": {
                          "type": "object",
                          "additionalProperties": true,
                          "description": "Embedded params for the base family."
                        },
                        "noiseAmplitude": {
                          "type": "number",
                          "minimum": 0.0,
                          "maximum": 1.0
                        },
                        "noiseBandwidthNorm": {
                          "type": "number",
                          "minimum": 0.0,
                          "maximum": 1.0,
                          "description": "Normalized bandwidth of noise; mapped to non-strobe-safe band."
                        },
                        "yMin": { "type": "number" },
                        "yMax": { "type": "number" }
                      }
                    },
                    "metric_aware": {
                      "type": "object",
                      "description": "Parameters for multi-input metric- and invariant-aware mappings.",
                      "additionalProperties": false,
                      "properties": {
                        "weights": {
                          "type": "object",
                          "description": "Linear weights for each input metric/invariant.",
                          "additionalProperties": {
                            "type": "number"
                          }
                        },
                        "bias": {
                          "type": "number"
                        },
                        "nonlinearity": {
                          "type": "string",
                          "enum": [ "none", "tanh", "relu", "sigmoid" ]
                        },
                        "yMin": { "type": "number" },
                        "yMax": { "type": "number" }
                      }
                    }
                  }
                },
                "conditions": {
                  "type": "object",
                  "description": "Optional per-mapping gating conditions.",
                  "additionalProperties": false,
                  "properties": {
                    "minUEC": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
                    "maxUEC": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
                    "minARR": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
                    "maxARR": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
                    "minCDL": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
                    "maxCDL": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
                    "minSignalQuality": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
                    "disableOnLowSignal": {
                      "type": "boolean",
                      "description": "Disable mapping when signalQuality falls below minSignalQuality."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "safety": {
      "type": "object",
      "description": "Global safety constraints shared by all profiles in this config.",
      "additionalProperties": false,
      "properties": {
        "globalMaxSlopePerSec": {
          "type": "number",
          "minimum": 0.0,
          "description": "Global hard cap on dy/dt for any channel."
        },
        "globalExposureSecondsCap": {
          "type": "number",
          "minimum": 0.0,
          "description": "Global cap on cumulative time above high-tension outputs per session."
        },
        "minSignalQuality": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Minimum signal quality below which BCI-driven mappings must be disabled."
        },
        "fallbackBehavior": {
          "type": "string",
          "enum": [ "scriptedonly", "reducedintensity", "holdlastsafe" ],
          "description": "Behavior when BCI mappings are disabled, e.g. poor signal."
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "description": "Lifecycle and promotion metadata for this binding.",
      "required": [ "tier", "promotionCriteriaRef" ],
      "additionalProperties": false,
      "properties": {
        "tier": {
          "type": "string",
          "enum": [ "lab", "standard", "mature" ],
          "description": "Lifecycle tier for this binding."
        },
        "promotionCriteriaRef": {
          "type": "string",
          "description": "ID of a shared promotion criteria artifact that defines quantitative thresholds."
        },
        "promotedFrom": {
          "type": "string",
          "enum": [ "lab", "standard" ],
          "description": "Previous lifecycle tier, if this binding has been promoted."
        },
        "promotedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of last promotion."
        },
        "promotionEvidenceRef": {
          "type": "array",
          "description": "References to telemetry summaries and reports that justify promotion.",
          "items": { "type": "string" }
        },
        "createdBy": {
          "type": "string",
          "description": "ID of human or tool that created this binding."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp."
        }
      }
    },
    "features": {
      "type": "object",
      "description": "Feature flags controlling optional behavior and rollout of new mapping capabilities.",
      "additionalProperties": false,
      "properties": {
        "enableNewOutputChannel": {
          "type": "boolean",
          "description": "Gate for using any optional or newly introduced output channels."
        },
        "enableExperimentalFamilyCode": {
          "type": "boolean",
          "description": "Gate for using experimental mapping families reserved for lab/standard tiers."
        },
        "enableAdvancedSafetyDiagnostics": {
          "type": "boolean",
          "description": "Gate for emitting additional safety diagnostics in telemetry."
        }
      }
    },
    "inputDomain": {
      "type": "object",
      "description": "Binding to a specific invariants/metrics spine and input-domain definition.",
      "required": [ "version", "metricsSchemaRef", "invariantsSchemaRef" ],
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "string",
          "description": "Identifier for the invariants/metrics spine version, e.g. invariants-metrics-spine-v2."
        },
        "metricsSchemaRef": {
          "type": "string",
          "description": "Schema ID for metrics envelope, e.g. bci-metrics-envelope-v2."
        },
        "invariantsSchemaRef": {
          "type": "string",
          "description": "Schema ID for invariants/metrics spine."
        },
        "notes": {
          "type": "string",
          "description": "Optional notes about the input-domain assumptions and corridors."
        }
      }
    }
  }
}
