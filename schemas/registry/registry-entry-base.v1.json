{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema:Horror.Place/constellation/registry-entry-base.v1",
  "title": "Registry Entry Base v1",
  "description": "Base schema for NDJSON registry entries across the HorrorPlace constellation. All registry entries must extend this schema via allOf.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schemaref",
    "tier",
    "metadata"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable, globally unique identifier for this registry entity. Format: TYPE-CODE-SEQUENCE (e.g., REG-ARAL-0001).",
      "pattern": "^[A-Z]{2,4}-[A-Z0-9]{2,8}-\\d{4}$"
    },
    "schemaref": {
      "type": "string",
      "description": "Canonical schema URI this entry conforms to.",
      "pattern": "^schema:Horror\\.Place/.+"
    },
    "tier": {
      "type": "integer",
      "description": "Visibility / governance tier: 1=public, 2=vault, 3=lab.",
      "minimum": 1,
      "maximum": 3
    },
    "artifactid": {
      "type": "string",
      "description": "Opaque artifact identifier in a backing vault or repo."
    },
    "cid": {
      "type": "string",
      "description": "Content-addressed identifier (e.g., IPFS CID or equivalent)."
    },
    "deadledgerref": {
      "type": "object",
      "description": "Dead-Ledger binding for provenance and entitlement gating.",
      "additionalProperties": false,
      "required": [
        "proofEnvelopeId",
        "verifierRef",
        "circuitType",
        "protocolVersion"
      ],
      "properties": {
        "proofEnvelopeId": {
          "type": "string",
          "description": "ID of the ZKP proof envelope attesting this entity."
        },
        "verifierRef": {
          "type": "string",
          "description": "Opaque reference to the verifier/circuit registry entry."
        },
        "circuitType": {
          "type": "string",
          "description": "Name or class of the ZKP circuit used."
        },
        "protocolVersion": {
          "type": "string",
          "description": "Version string for the proof protocol."
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Non-contentful metadata for discovery and audit.",
      "additionalProperties": false,
      "required": [
        "name",
        "status",
        "createdAt"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "Short, human-readable label."
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "active",
            "archived",
            "deprecated"
          ],
          "description": "Lifecycle status for this entry."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 creation timestamp (UTC)."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 last updated timestamp (UTC)."
        },
        "tags": {
          "type": "array",
          "description": "Lowercase, hyphenated keywords for filtering and categorization.",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          }
        },
        "sourceRepo": {
          "type": "string",
          "description": "Origin repository for the implementation."
        }
      }
    }
  },
  "allOf": [
    {
      "anyOf": [
        { "required": ["artifactid"] },
        { "required": ["cid"] },
        { "required": ["deadledgerref"] }
      ]
    }
  ]
}
