{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://horror.place/constellation-contracts/core/schemas/repos-manifest-v1.json",
  "title": "HorrorPlace VM-Constellation Repos Manifest v1",
  "description": "Schema for the cross-constellation repository manifest used by HorrorPlace-Constellation-Contracts.",

  "type": "object",
  "required": ["constellation", "manifest_version", "updated", "identity", "governance", "repos"],
  "additionalProperties": false,

  "properties": {
    "constellation": {
      "type": "string",
      "minLength": 1
    },
    "manifest_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "updated": {
      "type": "string",
      "format": "date-time"
    },

    "identity": {
      "type": "object",
      "required": ["owner", "maintainer", "description"],
      "additionalProperties": false,
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "maintainer": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },

    "governance": {
      "type": "object",
      "required": ["policy_profile", "safety_tiers", "requires_deadledger_ref", "deadledger_repo"],
      "additionalProperties": false,
      "properties": {
        "policy_profile": {
          "type": "string",
          "minLength": 1
        },
        "safety_tiers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["standard", "mature", "research"]
          },
          "uniqueItems": true
        },
        "requires_deadledger_ref": {
          "type": "boolean"
        },
        "deadledger_repo": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+\\/[A-Za-z0-9_.-]+$"
        }
      }
    },

    "repos": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "repo", "tier", "role", "safety_tier", "ref", "description"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "repo": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_.-]+\\/[A-Za-z0-9_.-]+$"
          },
          "tier": {
            "type": "string",
            "enum": ["tier-1", "tier-2", "tier-3"]
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "safety_tier": {
            "type": "string",
            "enum": ["standard", "mature", "research"]
          },
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
